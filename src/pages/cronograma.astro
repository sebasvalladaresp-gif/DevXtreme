---
import Layout from '../layouts/Layout.astro';

const agenda = [
  { time: '09:00', title: 'Inauguración',          desc: 'Palabras de las autoridades y apertura oficial del evento (09:00 - 09:20).', tag: 'INICIO', color: 'var(--yellow)' },
  { time: '09:20', title: 'Explicación del entorno', desc: 'Introducción a la plataforma HackerRank, normas de envío y formato de puntuación (09:20 - 10:00).', tag: 'INFO', color: 'var(--orange)' },
  { time: '10:00', title: 'Competencia',            desc: 'Competencia principal en HackerRank. Resolución de problemas y envío de soluciones (10:00 - 14:00).', tag: 'COMP', color: 'var(--red)' },
  { time: '13:00', title: 'Break (opcional)',        desc: 'Pausa opcional de 15 minutos para quienes deseen (13:00 - 13:15).', tag: 'PAUSA', color: 'var(--orange)' },
  { time: '14:00', title: 'Premiación',             desc: 'Revisión final de puntajes y ceremonia de premiación (14:00 - 14:30).', tag: 'PREMIA', color: 'var(--yellow)' },
  { time: '14:30', title: 'Cierre',                 desc: 'Cierre oficial del evento y despedida.', tag: 'FIN', color: 'var(--orange)' }
];
---

<Layout title="Cronograma - DevXtreme">
  <section class="cronograma-wrapper">
    <div class="header">
      <span class="prefix reveal">// AGENDA DEL DÍA</span>
      <h1 class="main-title reveal delay-1">Horario de <span class="gradient-text neon-title">Competencia</span></h1>
    </div>

    <div class="timeline-container">
      {agenda.map((item, index) => (
        <div class="timeline-entry reveal-left" style={`--delay: ${0.12 + index * 0.08}s`}>

          <div class="time-column">
            <span class="time-stamp">{item.time}</span>
            <div class="indicator">
              <div class="outer-dot" style={`border-color: ${item.color}`}>
                <div class="inner-dot" style={`background: ${item.color}`}></div>
              </div>
              <div class="line"></div>
            </div>
          </div>

          <div class="info-card">
            <div class="card-accent-bar" style={`background: ${item.color}`}></div>
            <div class="card-header">
              <h3>{item.title}</h3>
              {item.tag && (
                <span class="status-tag" style={`color: ${item.color}; border-color: ${item.color}`}>
                  {item.tag}
                </span>
              )}
            </div>
            <p>{item.desc}</p>
          </div>

        </div>
      ))}
    </div>
  </section>
</Layout>

<style>
  .cronograma-wrapper {
    max-width: 800px;
    margin: 0 auto;
    padding: 80px 20px;
  }

  .prefix {
    color: var(--orange);
    font-weight: 800;
    font-family: monospace;
    letter-spacing: 2px;
  }

  .main-title {
    font-size: clamp(1.8rem, 5vw, 3rem);
    margin-top: 10px;
    margin-bottom: 60px;
    color: var(--text-primary);
    transition: color 0.4s ease;
  }

  .gradient-text {
    background: linear-gradient(90deg, var(--orange), var(--red));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .timeline-container {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── ENTRY ── */
  .timeline-entry {
    display: flex;
    gap: 30px;
  }

  /* ── TIME COLUMN ── */
  .time-column {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 80px;
  }

  .time-stamp {
    font-family: monospace;
    font-weight: 800;
    color: var(--text-time);
    font-size: 1.1rem;
    margin-bottom: 10px;
    transition: color 0.4s ease;
  }

  .indicator {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .outer-dot {
    width: 18px; height: 18px;
    border: 2px solid;
    border-radius: 4px;
    display: flex;
    justify-content: center;
    align-items: center;
    background: var(--bg-card);
    z-index: 2;
    transition: background 0.4s ease, box-shadow 0.3s ease;
  }

  .timeline-entry:hover .outer-dot {
    box-shadow: 0 0 10px currentColor;
  }

  .inner-dot {
    width: 8px; height: 8px;
    border-radius: 1px;
    animation: dotPulse 2s ease-in-out infinite;
  }

  @keyframes dotPulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%       { transform: scale(1.3); opacity: 0.7; }
  }

  .line {
    width: 2px;
    flex-grow: 1;
    background: linear-gradient(to bottom, var(--orange), transparent);
    margin: 5px 0;
    opacity: 0.5;
  }

  [data-theme="dark"] .line { opacity: 0.8; }

  .timeline-entry:last-child .line { display: none; }

  /* ── INFO CARD ── */
  .info-card {
    background: var(--bg-card);
    border: 1px solid var(--border-default);
    padding: 25px;
    margin-bottom: 40px;
    flex-grow: 1;
    transition: transform 0.35s ease,
                border-color 0.35s ease,
                box-shadow 0.35s ease,
                background 0.4s ease;
    box-shadow: var(--card-box-shadow);
    position: relative;
    overflow: hidden;
  }

  /* Left accent bar */
  .card-accent-bar {
    position: absolute;
    left: 0; top: 0;
    width: 3px; height: 100%;
    transform: scaleY(0.3);
    transform-origin: top;
    transition: transform 0.4s ease;
  }

  .info-card:hover { transform: translateX(10px); }
  .info-card:hover .card-accent-bar { transform: scaleY(1); }
  .info-card:hover { border-color: var(--orange); }

  [data-theme="dark"] .info-card:hover {
    box-shadow: 8px 8px 0px rgba(255,122,0,0.15);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }

  .card-header h3 {
    font-size: 1.2rem;
    color: var(--text-card-title);
    transition: color 0.4s ease;
  }

  .status-tag {
    font-size: 0.65rem;
    font-weight: 800;
    padding: 2px 8px;
    border: 1px solid;
    font-family: monospace;
    letter-spacing: 1px;
  }

  .info-card p {
    color: var(--text-muted);
    line-height: 1.5;
    font-size: 0.95rem;
    transition: color 0.4s ease;
  }

  @media (max-width: 600px) {
    .timeline-entry { gap: 15px; }
    .time-column { min-width: 60px; }
    .time-stamp { font-size: 0.9rem; }
    .card-header { flex-direction: column; align-items: flex-start; gap: 6px; }
  }
</style>