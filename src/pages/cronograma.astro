---
import Layout from '../layouts/Layout.astro';

const schedule = [
  { time: "08:30", act: "Acreditación y Asignación de Laboratorios", type: "logistic" },
  { time: "09:00", act: "Inauguración DevXtreme v3.0", type: "main" },
  { time: "09:30", act: "Inicio de la Competencia (HackerRank habilitado)", type: "code" },
  { time: "11:30", act: "Checkpoint 1 - Actualización de Leaderboard", type: "alert" },
  { time: "13:30", act: "Cierre de Plataforma", type: "alert" },
  { time: "13:45", act: "Revisión Final de Código por el Jurado", type: "main" },
  { time: "14:00", act: "Premiación y Clausura", type: "main" }
];
---

<Layout title="Cronograma - DevXtreme 3.0">
  <section class="schedule-section">
    <div class="header-content reveal">
      <span class="eyebrow">// MISSION TIMELINE</span>
      <h1 class="page-title">Cronograma <span class="gradient-text">Oficial</span></h1>
      <p class="page-subtitle">Sincroniza tus relojes. La ventana de ejecución es crítica.</p>
    </div>

    <div class="timeline-container">
      <div class="timeline-line"></div>
      
      {schedule.map((item, i) => (
        <div class="timeline-node reveal-left" style={`--delay: ${0.1 + i * 0.15}s`}>
          
          <div class="time-block">
            <span class="time-text">{item.time}</span>
          </div>

          <div class="node-connector">
            <div class={`node-dot ${item.type}`}></div>
          </div>

          <div class={`event-card ${item.type}`}>
            <div class="event-glow"></div>
            <p class="event-act">{item.act}</p>
          </div>

        </div>
      ))}
    </div>
  </section>
</Layout>

<style>
  .schedule-section {
    max-width: 900px;
    margin: 0 auto;
    padding: 80px 20px 100px;
  }

  .header-content {
    text-align: center;
    margin-bottom: 80px;
  }

  .eyebrow {
    font-family: monospace;
    color: var(--orange);
    letter-spacing: 4px;
    font-size: 0.8rem;
    font-weight: 700;
    display: block;
    margin-bottom: 16px;
  }

  .page-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 1;
    margin-bottom: 20px;
    letter-spacing: -1px;
  }

  .gradient-text {
    background: linear-gradient(to right, var(--orange), var(--orange-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
  }

  /* ── TIMELINE ── */
  .timeline-container {
    position: relative;
    padding-left: 20px;
  }

  .timeline-line {
    position: absolute;
    left: 140px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, transparent, var(--border-subtle) 10%, var(--border-subtle) 90%, transparent);
    z-index: 1;
  }

  .timeline-node {
    display: flex;
    align-items: center;
    margin-bottom: 40px;
    position: relative;
    z-index: 2;
  }

  .time-block {
    width: 100px;
    flex-shrink: 0;
    text-align: right;
    padding-right: 20px;
  }

  .time-text {
    font-family: monospace;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--green);
    text-shadow: 0 0 10px rgba(0, 255, 157, 0.3);
  }

  .node-connector {
    width: 40px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .node-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 0 0 4px var(--bg-dark);
    position: relative;
    z-index: 3;
  }
  .node-dot.logistic { background: var(--text-secondary); }
  .node-dot.main { background: var(--orange); box-shadow: 0 0 0 4px var(--bg-dark), 0 0 15px var(--orange); }
  .node-dot.code { background: var(--green); box-shadow: 0 0 0 4px var(--bg-dark), 0 0 15px var(--green); }
  .node-dot.alert { background: #ff3366; box-shadow: 0 0 0 4px var(--bg-dark), 0 0 15px #ff3366; }

  .event-card {
    flex: 1;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 16px;
    padding: 24px 30px;
    margin-left: 20px;
    position: relative;
    overflow: hidden;
    backdrop-filter: var(--glass-blur);
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .event-card:hover {
    transform: translateX(10px);
  }

  .event-card.logistic:hover { border-color: var(--text-secondary); }
  .event-card.main:hover { border-color: var(--orange); }
  .event-card.code:hover { border-color: var(--green); }
  .event-card.alert:hover { border-color: #ff3366; }

  .event-glow {
    position: absolute;
    top: 0; left: 0; bottom: 0; width: 4px;
    background: #fff;
    opacity: 0.5;
  }
  .event-card.logistic .event-glow { background: var(--text-secondary); }
  .event-card.main .event-glow { background: var(--orange); }
  .event-card.code .event-glow { background: var(--green); }
  .event-card.alert .event-glow { background: #ff3366; }

  .event-act {
    font-size: 1.1rem;
    font-weight: 500;
    color: #fff;
    margin: 0;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .timeline-container { padding-left: 0; }
    .timeline-line { left: 30px; }
    .timeline-node { flex-direction: column; align-items: flex-start; }
    .time-block { text-align: left; padding-left: 50px; padding-right: 0; margin-bottom: 10px; }
    .node-connector { position: absolute; left: 10px; top: 0; height: 100%; align-items: flex-start; padding-top: 5px; }
    .event-card { margin-left: 50px; width: calc(100% - 50px); padding: 20px; }
  }
</style>