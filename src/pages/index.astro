</style>

<script>
  // ═══════════════════════════════════════════════════════════
  //  DevXtreme 3.0 — Motor de interacción de la landing (v2)
  // ═══════════════════════════════════════════════════════════
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isCoarse = window.matchMedia('(pointer: coarse)').matches;
  const landing = document.getElementById('landing');
  const isDark = () => document.documentElement.getAttribute('data-theme') === 'dark';

  // ── 1. Reveals REVERSIBLES: al subir, los elementos vuelven a
  //       su estado inicial y se re-animan al bajar de nuevo ────
  const revealEls = document.querySelectorAll('[data-animate]');
  revealEls.forEach((el) => {
    const d = el.getAttribute('data-delay');
    if (d) (el as HTMLElement).style.setProperty('--d', d);
  });
  const revealObs = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        e.target.classList.toggle('in-view', e.isIntersecting);
      }
    },
    { threshold: 0.12, rootMargin: '0px 0px -50px 0px' }
  );
  revealEls.forEach((el) => revealObs.observe(el));

  // ── 2. Sección activa: acento por tema + halo + dots + velo ──
  const panels = document.querySelectorAll<HTMLElement>('.panel');
  const dots = document.querySelectorAll<HTMLElement>('.dot');
  const veil = document.getElementById('section-veil');
  const veilLabel = document.getElementById('veil-label');
  let activePanel: HTMLElement | null = null;
  let particleTarget = [255, 122, 0];
  let navLock = false; // true mientras navegamos con parpadeo desde los puntos
  // parallax global del puntero (lo consumen el canvas y el foco de luz)
  let mparx = 0, mpary = 0;
  const sectionLabels: Record<string, string> = {};
  document.querySelectorAll<HTMLElement>('.dot').forEach((d) => {
    const lbl = d.querySelector('.dot-label');
    if (d.dataset.target && lbl) sectionLabels[d.dataset.target] = lbl.textContent || '';
  });

  const hexToRgb = (hex: string) => {
    const n = parseInt(hex.slice(1), 16);
    return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
  };

  const accentOf = (el: HTMLElement) =>
    (isDark() ? el.dataset.accentDark : el.dataset.accentLight) || '#ff7a00';

  const applyAccent = (el: HTMLElement) => {
    const accent = accentOf(el);
    landing?.style.setProperty('--sa', accent);
    particleTarget = hexToRgb(accent);
  };

  const setActivePanel = (el: HTMLElement) => {
    if (el === activePanel) return;
    activePanel = el;
    applyAccent(el);
    panels.forEach((p) => p.classList.toggle('active', p === el));
    dots.forEach((d) => d.classList.toggle('active', d.dataset.target === el.id));
  };

  const sectionObs = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) setActivePanel(e.target as HTMLElement);
      }
    },
    { rootMargin: '-45% 0px -45% 0px', threshold: 0 }
  );
  panels.forEach((p) => sectionObs.observe(p));

  // Si el usuario cambia de tema, se recalcula el acento de la sección activa
  new MutationObserver(() => {
    if (activePanel) applyAccent(activePanel);
  }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

  // ── 2b. NAVEGACIÓN CON PARPADEO desde los puntos de la derecha:
  //  fundido a negro → salto instantáneo a la sección → revelado ──
  dots.forEach((dot) => {
    dot.addEventListener('click', (e) => {
      const id = dot.dataset.target;
      const target = id ? document.getElementById(id) : null;
      if (!target || prefersReduced) return; // sin JS de por medio, ancla normal
      e.preventDefault();
      if (navLock || !veil) return;
      navLock = true;

      // 1) pantalla a negro con el nombre de la sección destino
      veil.classList.add('nav-fade');
      veil.style.opacity = '1';
      if (veilLabel && id) {
        veilLabel.textContent = `// ${sectionLabels[id] || ''}`;
        veilLabel.style.opacity = '1';
        veilLabel.style.transform = 'translate(-50%, -50%)';
      }

      setTimeout(() => {
        // 2) salto instantáneo mientras todo está en negro
        const r = target.getBoundingClientRect();
        const top = window.scrollY + r.top + r.height / 2 - window.innerHeight / 2;
        window.scrollTo({ top: Math.max(0, top), behavior: 'auto' });
        history.replaceState(null, '', `#${id}`);

        setTimeout(() => {
          // 3) revelado: la sección aparece desde el negro
          veil.style.opacity = '0';
          if (veilLabel) veilLabel.style.opacity = '0';
          setTimeout(() => {
            veil.classList.remove('nav-fade');
            navLock = false;
            onScroll();
          }, 380);
        }, 200);
      }, 380);
    });
  });

  // ── 3. Scroll optimizado: métricas cacheadas en resize/load,
  //       CERO lecturas de layout por frame de scroll ────────────
  const progressBar = document.getElementById('progress-bar');
  const timeline = document.getElementById('timeline');
  const timelineFill = document.getElementById('timeline-fill');
  let ticking = false;

  type Metric = { el: HTMLElement; top: number; h: number };
  let panelMetrics: Metric[] = [];
  let tlTop = 0, tlH = 1;
  const floatMeta: { el: HTMLElement; speed: number; panel: HTMLElement | null }[] = [];
  document.querySelectorAll<HTMLElement>('.float-el').forEach((el) => {
    floatMeta.push({ el, speed: parseFloat(el.dataset.speed || '0.15'), panel: el.closest('.panel') });
  });

  const measure = () => {
    const sy = window.scrollY;
    panelMetrics = Array.from(panels, (p) => {
      const r = p.getBoundingClientRect();
      return { el: p, top: r.top + sy, h: r.height };
    });
    if (timeline) {
      const r = timeline.getBoundingClientRect();
      tlTop = r.top + sy; tlH = r.height || 1;
    }
  };
  measure();
  window.addEventListener('resize', measure);
  window.addEventListener('load', measure);

  const onScroll = () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      const y = window.scrollY;
      const vh = window.innerHeight;
      const max = document.documentElement.scrollHeight - vh;
      if (progressBar) progressBar.style.transform = `scaleX(${max > 0 ? y / max : 0})`;

      if (!prefersReduced) {
        for (const f of floatMeta) {
          const m = f.panel ? panelMetrics.find((pm) => pm.el === f.panel) : null;
          if (m) f.el.style.transform = `translateY(${(m.top - y) * -f.speed}px)`;
        }
      }

      // Timeline reversible: se llena al bajar y se vacía al subir
      if (timelineFill) {
        const progress = Math.min(1, Math.max(0, (y + vh * 0.75 - tlTop) / tlH));
        timelineFill.style.transform = `scaleY(${progress})`;
      }

      // ── APAGÓN A NEGRO CONDUCIDO POR EL SCROLL ──────────────
      if (veil && !prefersReduced && !navLock) {
        const vc = y + vh / 2;
        let dmin = Infinity;
        let nearest: HTMLElement | null = null;
        for (const m of panelMetrics) {
          const d = Math.abs(m.top + m.h / 2 - vc) / (m.h * 0.55);
          if (d < dmin) { dmin = d; nearest = m.el; }
          // la sección saliente se encoge y desvanece hacia el negro
          const kk = Math.min(1, Math.max(0, (d - 0.45) / 0.55));
          m.el.style.opacity = String(1 - kk * 0.9);
          m.el.style.transform = kk > 0.001 ? `scale(${1 - kk * 0.05})` : '';
        }
        const k = Math.min(1, Math.max(0, (dmin - 0.5) / 0.35));
        veil.style.opacity = String(k);
        if (veilLabel && nearest) {
          const name = sectionLabels[(nearest as HTMLElement).id];
          if (name) veilLabel.textContent = `// ${name}`;
          veilLabel.style.opacity = String(k);
          veilLabel.style.transform =
            `translate(-50%, -50%) translateY(${(1 - k) * 30}px) scale(${0.9 + k * 0.1})`;
        }
      }
      ticking = false;
    });
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // ── 4. Typewriter del hero ───────────────────────────────────
  const tw = document.getElementById('typewriter');
  const twText = 'init devxtreme --edition=3.0 --mode=extreme';
  if (tw && !prefersReduced) {
    let i = 0;
    const type = () => {
      if (i <= twText.length) {
        tw.textContent = twText.slice(0, i++);
        setTimeout(type, 34 + Math.random() * 46);
      }
    };
    setTimeout(type, 500);
  } else if (tw) {
    tw.textContent = twText;
  }

  // ── 4b. FONDO INTERACTIVO AL PUNTERO (estilo peachweb) ──────
  //  Un foco de luz sigue al cursor, el título se inclina en 3D y
  //  el canvas de partículas se desplaza en parallax con el mouse.
  //  (el trabajo por-frame del puntero corre dentro del ÚNICO loop
  //   rAF del canvas — un solo loop para todo, menos CPU)
  const glow = document.getElementById('cursor-glow');
  const heroTitleEl = document.querySelector<HTMLElement>('.hero-title');
  const targetM = { x: window.innerWidth / 2, y: window.innerHeight * 0.38 };
  const curM = { x: targetM.x, y: targetM.y };
  if (!prefersReduced && !isCoarse) {
    window.addEventListener('pointermove', (e) => {
      targetM.x = e.clientX; targetM.y = e.clientY;
    }, { passive: true });
  }
  const ambientStep = () => {
    if (isCoarse) return;
    curM.x += (targetM.x - curM.x) * 0.08;
    curM.y += (targetM.y - curM.y) * 0.08;
    if (glow) {
      glow.style.setProperty('--mx', `${curM.x}px`);
      glow.style.setProperty('--my', `${curM.y}px`);
    }
    mparx = curM.x / window.innerWidth - 0.5;
    mpary = curM.y / window.innerHeight - 0.5;
    if (heroTitleEl) {
      heroTitleEl.style.transform =
        `perspective(900px) rotateX(${mpary * -6}deg) rotateY(${mparx * 8}deg)`;
    }
  };

  // ── 5. Tilt 3D + glare + botones magnéticos ─────────────────
  if (!prefersReduced && !isCoarse) {
    document.querySelectorAll<HTMLElement>('.tilt').forEach((card) => {
      card.addEventListener('pointermove', (ev) => {
        const r = card.getBoundingClientRect();
        const px = (ev.clientX - r.left) / r.width;
        const py = (ev.clientY - r.top) / r.height;
        const rx = (py - 0.5) * -10;
        const ry = (px - 0.5) * 10;
        card.style.transform = `perspective(700px) rotateX(${rx}deg) rotateY(${ry}deg) translateY(-4px)`;
        card.style.setProperty('--gx', `${px * 100}%`);
        card.style.setProperty('--gy', `${py * 100}%`);
      });
      card.addEventListener('pointerleave', () => {
        card.style.transform = 'perspective(700px) rotateX(0) rotateY(0)';
      });
    });

    document.querySelectorAll<HTMLElement>('.magnetic').forEach((btn) => {
      btn.addEventListener('pointermove', (ev) => {
        const r = btn.getBoundingClientRect();
        const dx = ev.clientX - (r.left + r.width / 2);
        const dy = ev.clientY - (r.top + r.height / 2);
        btn.style.transform = `translate(${dx * 0.18}px, ${dy * 0.28}px)`;
      });
      btn.addEventListener('pointerleave', () => {
        btn.style.transform = 'translate(0, 0)';
      });
    });
  }

  // ── 6. Canvas: partículas de fondo + LOGO-PARTÍCULAS ────────
  //       El logo IEEE se forma con partículas, se dispersa al
  //       cambiar de sección y se vuelve a formar en otra parte
  //       de la página.
  const canvas = document.getElementById('particles') as HTMLCanvasElement | null;
  if (canvas && !prefersReduced) {
    const ctx = canvas.getContext('2d')!;
    let W = 0, H = 0;
    let color = [255, 122, 0];
    const mouse = { x: -9999, y: -9999 };

    const resize = () => {
      W = canvas.width = window.innerWidth;
      H = canvas.height = window.innerHeight;
    };
    resize();
    window.addEventListener('resize', resize);
    window.addEventListener('pointermove', (e) => { mouse.x = e.clientX; mouse.y = e.clientY; }, { passive: true });
    window.addEventListener('pointerleave', () => { mouse.x = -9999; mouse.y = -9999; });

    // — partículas ambientales —
    const COUNT = isCoarse ? 30 : Math.min(70, Math.floor(window.innerWidth / 20));
    const parts = Array.from({ length: COUNT }, () => ({
      x: Math.random() * window.innerWidth,
      y: Math.random() * window.innerHeight,
      vx: (Math.random() - 0.5) * 0.35,
      vy: (Math.random() - 0.5) * 0.35,
      r: 1 + Math.random() * 1.8,
    }));
    const LINK = isCoarse ? 90 : 130;

    // — logo-partículas —
    type LogoP = { x: number; y: number; vx: number; vy: number; ox: number; oy: number; s: number };
    let logoParts: LogoP[] = [];
    let logoScatter = 0;
    // posición (fracción de viewport) del logo según la sección activa
    const logoAnchors: Record<string, { x: number; y: number }> = {
      hero:       { x: 0.85, y: 0.30 },
      evento:     { x: 0.12, y: 0.72 },
      categorias: { x: 0.87, y: 0.76 },
      cronograma: { x: 0.12, y: 0.36 },
      premios:    { x: 0.86, y: 0.30 },
      reglas:     { x: 0.13, y: 0.66 },
      registro:   { x: 0.50, y: 0.20 },
    };
    let logoAnchor = logoAnchors.hero;
    let lastAnchorId = 'hero';

    const logoImg = new Image();
    logoImg.src = '/Logo_Solo_Cs.webp';
    logoImg.onload = () => {
      try {
        const lw = 350;
        const ratio = logoImg.naturalWidth > 0 ? logoImg.naturalHeight / logoImg.naturalWidth : 0.35;
        const lh = Math.max(30, Math.round(lw * ratio));
        const oc = document.createElement('canvas');
        oc.width = lw; oc.height = lh;
        const octx = oc.getContext('2d')!;
        octx.drawImage(logoImg, 0, 0, lw, lh);
        const data = octx.getImageData(0, 0, lw, lh).data;
        const targets: { ox: number; oy: number }[] = [];
        const step = 2;
        for (let yy = 0; yy < lh; yy += step) {
          for (let xx = 0; xx < lw; xx += step) {
            if (data[(yy * lw + xx) * 4 + 3] > 100) {
              targets.push({ ox: xx - lw / 2, oy: yy - lh / 2 });
            }
          }
        }
        // limitar cantidad para rendimiento
        const MAXP = isCoarse ? 1000 : 2000;
        while (targets.length > MAXP) targets.splice(Math.floor(Math.random() * targets.length), 1);
        logoParts = targets.map((t) => ({
          x: Math.random() * W,
          y: Math.random() * H,
          vx: 0, vy: 0,
          ox: t.ox, oy: t.oy,
          s: 3 + Math.random(),
        }));
      } catch { /* si el SVG no se puede muestrear, seguimos sin logo-partículas */ }
    };

    // dispersar el logo cuando cambia la sección activa
    const scatterLogo = () => {
      logoScatter = 45;
      for (const lp of logoParts) {
        lp.vx = (Math.random() - 0.5) * 16;
        lp.vy = (Math.random() - 0.5) * 16;
      }
    };
    const sectionStep = () => {
      const current = activePanel?.id || 'hero';
      if (current !== lastAnchorId) {
        lastAnchorId = current;
        logoAnchor = logoAnchors[current] || logoAnchors.hero;
        scatterLogo();
      }
    };

    let frame = 0;
    const draw = () => {
      frame++;
      // táctil/móvil: 30fps es suficiente y ahorra batería
      if (isCoarse && frame % 2) { requestAnimationFrame(draw); return; }
      ambientStep();
      sectionStep();
      ctx.clearRect(0, 0, W, H);
      const t = performance.now();
      // lerp de color hacia el acento de la sección activa
      for (let c = 0; c < 3; c++) color[c] += (particleTarget[c] - color[c]) * 0.04;
      const [cr, cg, cb] = color.map(Math.round);
      const baseAlpha = isDark() ? 0.55 : 0.4;
      ctx.fillStyle = `rgba(${cr},${cg},${cb},${baseAlpha})`; // una sola vez por frame

      // — ambientales —
      for (const p of parts) {
        const dx = p.x - mouse.x, dy = p.y - mouse.y;
        const dist2 = dx * dx + dy * dy;
        if (dist2 < 16000) {
          const f = 0.6 / Math.max(dist2, 400);
          p.vx += dx * f; p.vy += dy * f;
        }
        p.vx *= 0.995; p.vy *= 0.995;
        p.x += p.vx; p.y += p.vy;
        if (p.x < -20) p.x = W + 20; if (p.x > W + 20) p.x = -20;
        if (p.y < -20) p.y = H + 20; if (p.y > H + 20) p.y = -20;

        ctx.beginPath();
        ctx.arc(p.x + mparx * 26, p.y + mpary * 18, p.r, 0, Math.PI * 2);
        ctx.fill();
      }

      // enlaces: distancia al cuadrado (sin sqrt) + globalAlpha
      // (evita construir un string rgba() por cada par de partículas)
      const L2 = LINK * LINK;
      const linkAlpha = isDark() ? 0.22 : 0.15;
      ctx.strokeStyle = `rgb(${cr},${cg},${cb})`;
      ctx.lineWidth = 1;
      for (let a = 0; a < parts.length; a++) {
        for (let b = a + 1; b < parts.length; b++) {
          const dx = parts[a].x - parts[b].x;
          const dy = parts[a].y - parts[b].y;
          const d2 = dx * dx + dy * dy;
          if (d2 < L2) {
            ctx.globalAlpha = (1 - d2 / L2) * linkAlpha;
            ctx.beginPath();
            ctx.moveTo(parts[a].x + mparx * 26, parts[a].y + mpary * 18);
            ctx.lineTo(parts[b].x + mparx * 26, parts[b].y + mpary * 18);
            ctx.stroke();
          }
        }
      }
      ctx.globalAlpha = 1;

      // — logo-partículas: dispersión y re-formación —
      if (logoParts.length) {
        const scale = Math.max(0.55, Math.min(1, W / 1200));
        const ax = logoAnchor.x * W + mparx * 48;  // parallax de capa profunda
        const ay = logoAnchor.y * H + Math.sin(t * 0.0012) * 10 + mpary * 30;
        const scattering = logoScatter > 0;
        if (scattering) logoScatter--;

        ctx.fillStyle = `rgba(${cr},${cg},${cb},${isDark() ? 0.75 : 0.65})`;
        for (const lp of logoParts) {
          if (scattering) {
            lp.vx *= 0.92; lp.vy *= 0.92;
            lp.x += lp.vx; lp.y += lp.vy;
          } else {
            // el mouse también dispersa localmente el logo
            const mdx = lp.x - mouse.x, mdy = lp.y - mouse.y;
            const md2 = mdx * mdx + mdy * mdy;
            if (md2 < 5200) {
              lp.x += mdx * 0.06;
              lp.y += mdy * 0.06;
            }
            lp.x += (ax + lp.ox * scale - lp.x) * 0.07;
            lp.y += (ay + lp.oy * scale - lp.y) * 0.07;
          }
          ctx.fillRect(lp.x, lp.y, lp.s, lp.s);
        }
      }

      requestAnimationFrame(draw);
    };
    draw();
  }
</script>
