---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';

const stats = [
  { label: "FECHA", value: "15 MAYO" },
  { label: "INICIO", value: "09:00" },
  { label: "CIERRE", value: "14:00" },
  { label: "DURACIÓN", value: "4 HRS" },
];
---

<Layout title="DevXtreme">
  <main>

    <div class="title">
      <span class="reveal">DEVXTREME 3.0</span>
    </div>

    <p class="description reveal delay-2">
      Demuestra tu dominio del código. El evento dura 4 horas: inauguración, explicación del entorno y una
      competencia práctica en HackerRank con clasificación por puntos.
    </p>

    <div class="stats">
      {stats.map((item, index) => (
        <div class="card reveal-zoom" style={`--delay: ${0.2 + index * 0.08}s`}>
          <div class="card-inner">
            <span>{item.label}</span>
            <h3>{item.value}</h3>
          </div>
          <div class="card-shine"></div>
        </div>
      ))}
    </div>

    <div class="buttons">
      <a href="/Explorar"   class="btn reveal" style="--delay: 0.4s"><span>EXPLORAR EVENTO</span></a>
      <a href="/cronograma" class="btn reveal" style="--delay: 0.48s"><span>CRONOGRAMA</span></a>
      <a href="/categorias" class="btn reveal" style="--delay: 0.56s"><span>CATEGORÍAS</span></a>
      <a href="/reglas"     class="btn reveal" style="--delay: 0.64s"><span>REGLAS</span></a>
      <a href="/registro"
         target="_blank" class="btn btn-cta reveal" style="--delay: 0.72s"><span>REGISTRARSE</span></a>
    </div>

  </main>
</Layout>

<style>
  main {
    padding: 60px 20px;
    text-align: center;
    position: relative;
    z-index: 10;
  }

  /* ── TITLE ── */
  .title {
    width: 100%;
    overflow: hidden;
    margin-bottom: 20px;
    display: flex;
    justify-content: center;
  }

  .title span {
    display: block;
    font-size: clamp(1.4rem, 10vw, 8rem);
    font-weight: 800;
    line-height: 1.1;
    white-space: nowrap;
    background: linear-gradient(90deg, var(--yellow), var(--orange), var(--red));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-transform: uppercase;
    letter-spacing: -1px;
    text-align: center;
    filter: drop-shadow(0 0 30px rgba(255, 122, 0, 0.15));
    animation: titlePop 0.8s cubic-bezier(0.2, 0.7, 0.2, 1) forwards, titleGlow 4s ease-in-out 0.8s infinite alternate;
  }

  [data-theme="dark"] .title span {
    filter: drop-shadow(0 0 40px rgba(255, 122, 0, 0.4));
  }

  @keyframes titlePop {
    from { opacity: 0; transform: scale(0.95) translateY(10px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }
  @keyframes titleGlow {
    from { filter: drop-shadow(0 0 20px rgba(255, 122, 0, 0.15)); }
    to   { filter: drop-shadow(0 0 50px rgba(255, 122, 0, 0.35)); }
  }

  /* ── DESCRIPTION ── */
  .description {
    max-width: 650px;
    margin: 0 auto 50px;
    line-height: 1.6;
    color: var(--orange);
    font-weight: 500;
    font-size: clamp(0.85rem, 3vw, 1rem);
    padding: 0 10px;
  }

  /* ── STATS GRID ── */
  .stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    max-width: 700px;
    margin: 0 auto 60px;
  }

  .card {
    background: var(--bg-card);
    border: 1px solid var(--border-accent);
    padding: 24px 20px;
    position: relative;
    overflow: hidden;
    cursor: default;
    transition: transform 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275),
                box-shadow 0.35s ease,
                border-color 0.35s ease;
  }

  .card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: var(--shadow-card-hover);
    border-color: var(--orange);
  }

  .card-inner { position: relative; z-index: 2; }

  .card span {
    font-size: 0.7rem;
    letter-spacing: 2px;
    color: var(--text-faint);
    display: block;
  }

  .card h3 {
    font-size: 1.5rem;
    color: var(--orange);
    margin-top: 5px;
  }

  /* Shine sweep on hover */
  .card-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0) 40%, rgba(255,200,100,0.08) 50%, rgba(255,255,255,0) 60%);
    background-size: 200% 200%;
    background-position: 200% 200%;
    transition: background-position 0.6s ease;
    z-index: 1;
  }

  .card:hover .card-shine {
    background-position: -50% -50%;
  }

  [data-theme="dark"] .card-shine {
    background: linear-gradient(135deg, rgba(255,255,255,0) 40%, rgba(255,200,100,0.05) 50%, rgba(255,255,255,0) 60%);
    background-size: 200% 200%;
    background-position: 200% 200%;
  }

  /* ── BUTTONS ── */
  .buttons {
    display: flex;
    justify-content: center;
    gap: 15px;
    flex-wrap: wrap;
    max-width: 1200px;
    margin: 0 auto;
  }

  .btn {
    min-width: 200px;
    padding: 15px 25px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 1px;
    border: 2px solid var(--orange);
    background: var(--bg-card);
    display: inline-block;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,122,0,0.06), transparent);
    transform: translateX(-100%);
    transition: transform 0.5s ease;
  }

  .btn:hover::before { transform: translateX(100%); }

  .btn:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(255, 122, 0, 0.2);
    border-color: var(--yellow);
  }

  .btn span {
    background: linear-gradient(90deg, var(--yellow), var(--orange), var(--red));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    position: relative;
    z-index: 2;
  }

  .btn-cta {
    border-color: var(--red);
    background: linear-gradient(135deg, rgba(255, 0, 76, 0.25), rgba(255, 122, 0, 0.2));
    animation: ctaPulse 2.5s ease-in-out infinite;
  }

  .btn-cta span {
    background: var(--red) !important;
    -webkit-text-fill-color: white !important;
    -webkit-background-clip: unset !important;
    padding: 10px 10px;
    border-radius: 5%;

  }

  [data-theme="dark"] .btn-cta {
    background: linear-gradient(135deg, rgba(255, 0, 76, 0.12), rgba(255, 122, 0, 0.1));
  }

  [data-theme="dark"] .btn-cta span {
    background: linear-gradient(90deg, var(--yellow), var(--orange), var(--red)) !important;
    -webkit-text-fill-color: transparent !important;
    -webkit-background-clip: text !important;

  }

  .btn-cta.reveal {
    animation: revealUp 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) forwards,
               ctaPulse 2.5s ease-in-out infinite;
    animation-delay: var(--delay, 0s), 0s;
  }

  @keyframes ctaPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255,0,76,0); }
    50%       { box-shadow: 0 0 0 6px rgba(255,0,76,0.1); }
  }

  @media (max-width: 400px) {
    .title span { font-size: 1.5rem; letter-spacing: -2px; }
    .description { font-size: 0.85rem; padding: 0 5px; }
  }
</style>