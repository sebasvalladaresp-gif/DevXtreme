---
// src/pages/index.astro — Landing one-page DevXtreme 3.0 (scroll experience v2)
import Layout from '../layouts/Layout.astro';

const stats = [
  { label: "FECHA", value: "15 MAYO" },
  { label: "INICIO", value: "09:00" },
  { label: "CIERRE", value: "14:00" },
  { label: "DURACIÓN", value: "4 HRS" },
];

const aboutStats = [
  { value: "4",  suffix: "H",  label: "DE COMPETENCIA", color: "var(--red)" },
  { value: "3",  suffix: ".0", label: "EDICIÓN",        color: "var(--orange)" },
  { value: "N+1", suffix: "",  label: "RETOS TÉCNICOS", color: "var(--yellow)" },
  { value: "∞",  suffix: "",   label: "LÍNEAS DE CÓDIGO", color: "var(--red)" },
];

const categories = [
  { title: "Algoritmos & Complejidad", icon: "⚡", desc: "Optimización, estructuras avanzadas, ordenamiento y análisis Big-O.", color: "var(--yellow)", code: "void solve() { O(log n); }" },
  { title: "Lógica & Matemáticas", icon: "🧠", desc: "Combinatoria, teoría de números, grafos y matemática discreta.", color: "var(--red)", code: "P ∩ Q = { x | x ∈ P ∧ x ∈ Q }" },
  { title: "Programación Práctica", icon: "🛠️", desc: "Lógica de negocio, flujos de datos y soluciones eficientes.", color: "var(--orange)", code: "git commit -m 'feat: optimized'" },
  { title: "Estructuras de Datos", icon: "📚", desc: "Pilas, colas, árboles, hash tables y grafos aplicados a algoritmos.", color: "var(--red)", code: "vector<int> v; // estructura" },
];

const agenda = [
  { time: '09:00', title: 'Inauguración',            desc: 'Apertura oficial del evento.',                        tag: 'INICIO', color: 'var(--yellow)' },
  { time: '09:20', title: 'Explicación del entorno', desc: 'HackerRank, normas de envío y puntuación.',           tag: 'INFO',   color: 'var(--orange)' },
  { time: '10:00', title: 'Competencia',             desc: 'Resolución de problemas y envío de soluciones.',      tag: 'COMP',   color: 'var(--red)' },
  { time: '13:00', title: 'Break (opcional)',        desc: 'Pausa de 15 minutos para quienes deseen.',            tag: 'PAUSA',  color: 'var(--orange)' },
  { time: '14:00', title: 'Premiación',              desc: 'Revisión de puntajes y ceremonia de premiación.',     tag: 'PREMIA', color: 'var(--yellow)' },
  { time: '14:30', title: 'Cierre',                  desc: 'Cierre oficial del evento y despedida.',              tag: 'FIN',    color: 'var(--orange)' },
];

const premios = [
  { lugar: "2º", titulo: "Segundo lugar", desc: "Producto IEEE y Pingüino Linux para los integrantes", imgs: ["trofeoIee.webp", "pinguinitoLinux.webp"], color: "#c0c0c0", h: "podium-2", anim: "left" },
  { lugar: "1º", titulo: "Primer lugar",  desc: "Trofeo por integrante, Producto IEEE y Pingüino Linux", imgs: ["trofeo.webp", "trofeoIee.webp", "pinguinitoLinux.webp"], color: "#ffd700", h: "podium-1", anim: "zoom" },
  { lugar: "3º", titulo: "Tercer lugar",  desc: "Pingüino Linux para los integrantes", imgs: ["pinguinitoLinux.webp"], color: "#cd7f32", h: "podium-3", anim: "right" },
];

const rules = [
  'No se permite la comunicación entre equipos durante la competencia.',
  'Copia entre equipos = descalificación inmediata.',
  'IA solo para aprender o generar ideas, nunca soluciones completas.',
  'Equipos de 3 personas.',
  'Cualquier lenguaje soportado por HackerRank.',
];

const marquee = ['ALGORITMOS', 'HACKERRANK', 'BIG-O', 'GRAFOS', 'C++', 'PYTHON', 'JAVA', 'DEBUG', 'COMPILE', 'SUBMIT', 'ACCEPTED ✓'];

const heroTitle = "DEVXTREME";

// Acento por sección y por tema:
// claro = tonos fríos (azul eléctrico / marino) · oscuro = naranjas/ámbar (sin rojo)
const sections = [
  { id: 'hero',       label: 'Inicio',     light: '#0066ff', dark: '#ff7a00' },
  { id: 'evento',     label: 'El Evento',  light: '#00a3ff', dark: '#ffcc00' },
  { id: 'categorias', label: 'Categorías', light: '#0a2540', dark: '#ff9500' },
  { id: 'cronograma', label: 'Cronograma', light: '#0066ff', dark: '#ff7a00' },
  { id: 'premios',    label: 'Premios',    light: '#00a3ff', dark: '#ffd700' },
  { id: 'reglas',     label: 'Reglas',     light: '#0a2540', dark: '#22d3ee' },
  { id: 'registro',   label: 'Registro',   light: '#0066ff', dark: '#ff9500' },
];
const acc = (id: string) => sections.find((s) => s.id === id)!;
---

<Layout title="DevXtreme 3.0 — Competencia de Programación">
  <main id="landing">

    <!-- Canvas: partículas de fondo + logo-partículas -->
    <canvas id="particles" aria-hidden="true"></canvas>

    <!-- Apagón entre secciones: negro total conducido por el scroll -->
    <div id="section-veil" aria-hidden="true"><span id="veil-label"></span></div>

    <!-- Foco de luz que sigue al puntero (fondo interactivo) -->
    <div id="cursor-glow" aria-hidden="true"></div>

    <!-- Barra de progreso de scroll -->
    <div class="scroll-progress" aria-hidden="true"><span id="progress-bar"></span></div>

    <!-- Navegación por puntos (desktop) -->
    <nav class="dot-nav" aria-label="Secciones">
      {sections.map((s) => (
        <a href={`#${s.id}`} class="dot" data-target={s.id} aria-label={s.label}>
          <span class="dot-label">{s.label}</span>
        </a>
      ))}
    </nav>

    <!-- ═══════════════ HERO ═══════════════ -->
    <section id="hero" class="panel hero" data-accent-light={acc('hero').light} data-accent-dark={acc('hero').dark}>
      <div class="float-el" data-speed="0.15" style="top:18%; left:6%;">&#123; &#125;</div>
      <div class="float-el" data-speed="-0.1" style="top:30%; right:8%;">&lt;/&gt;</div>
      <div class="float-el" data-speed="0.25" style="bottom:22%; left:12%;">01</div>
      <div class="float-el" data-speed="-0.2" style="bottom:30%; right:14%;">;</div>

      <p class="hero-terminal" aria-hidden="true">
        <span class="prompt">$</span> <span id="typewriter"></span><span class="cursor">▌</span>
      </p>

      <h1 class="hero-title" aria-label="DevXtreme 3.0">
        <span class="glitch-wrap">
          {heroTitle.split('').map((ch, i) => (
            <span class="letter" style={`--i:${i}`}>{ch}</span>
          ))}
        </span>
        <span class="hero-version">
          {"3.0".split('').map((ch, i) => (
            <span class="letter" style={`--i:${i + heroTitle.length}`}>{ch}</span>
          ))}
        </span>
      </h1>

      <p class="hero-desc" data-animate data-delay="3">
        Demuestra tu dominio del código. 4 horas de competencia práctica en
        HackerRank con clasificación por puntos. Algoritmos, lógica y presión real.
      </p>

      <div class="hero-stats">
        {stats.map((item, index) => (
          <div class="stat-chip tilt" data-animate={index % 2 ? 'right' : 'left'} data-delay={4 + index}>
            <span class="chip-label">{item.label}</span>
            <span class="chip-value">{item.value}</span>
            <span class="tilt-glare" aria-hidden="true"></span>
          </div>
        ))}
      </div>

      <div class="hero-actions" data-animate data-delay="8">
        <a href="/registro" target="_blank" class="btn btn-primary magnetic"><span>REGISTRARSE</span></a>
        <a href="#evento" class="btn btn-ghost magnetic"><span>EXPLORAR ▾</span></a>
      </div>

      <a href="#evento" class="scroll-hint" aria-label="Bajar">
        <span class="mouse"><span class="wheel"></span></span>
        SCROLL
      </a>
    </section>

    <!-- ═══════════════ MARQUEE ═══════════════ -->
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track">
        {[...marquee, ...marquee].map((w) => <span class="marquee-item">{w} <i>✦</i></span>)}
      </div>
    </div>

    <!-- ═══════════════ EL EVENTO ═══════════════ -->
    <section id="evento" class="panel" data-accent-light={acc('evento').light} data-accent-dark={acc('evento').dark}>
      <div class="float-el" data-speed="0.2" style="top:12%; right:6%;">while(true)</div>
      <div class="float-el" data-speed="-0.12" style="bottom:14%; left:5%;">return 0;</div>

      <header class="sec-head">
        <span class="sec-tag" data-animate="left">// ACERCA DEL EVENTO</span>
        <h2 class="sec-title" data-animate data-delay="1">¿Qué es <span class="accent-text">DevXtreme</span>?</h2>
      </header>

      <div class="about-grid">
        <!-- Bloque completo entra desde la izquierda -->
        <div class="about-text" data-animate="left" data-delay="2">
          <p>
            La tercera edición de la competencia que reúne a los mejores talentos en
            desarrollo de software para medirse en retos de <strong>algoritmos, lógica y
            resolución de problemas</strong> bajo presión real.
          </p>
          <p>
            Problemas diseñados para evaluar eficiencia, creatividad y dominio técnico
            en un entorno de alta intensidad.
          </p>
          <p class="about-cta">
            Solo tienes cuatro horas. Cada segundo cuenta.<br />
            <span class="accent-text">¿Estás listo para llevar tu código al límite?</span>
          </p>
          <a href="/Explorar" class="link-more">VER MÁS DEL EVENTO →</a>
        </div>

        <!-- Bloque completo entra desde la derecha -->
        <div class="about-stats" data-animate="right" data-delay="3">
          {aboutStats.map((s) => (
            <div class="about-stat tilt" style={`--bar: ${s.color}`}>
              <span class="stat-value">{s.value}<em>{s.suffix}</em></span>
              <span class="stat-label">{s.label}</span>
              <span class="stat-bar" aria-hidden="true"></span>
              <span class="tilt-glare" aria-hidden="true"></span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════ CATEGORÍAS ═══════════════ -->
    <section id="categorias" class="panel" data-accent-light={acc('categorias').light} data-accent-dark={acc('categorias').dark}>
      <div class="float-el" data-speed="0.18" style="top:10%; left:8%;">O(n log n)</div>
      <div class="float-el" data-speed="-0.15" style="bottom:12%; right:7%;">null</div>

      <header class="sec-head">
        <span class="sec-tag" data-animate="left">// ÁREAS EVALUADAS</span>
        <h2 class="sec-title" data-animate data-delay="1">Categorías de <span class="accent-text">Desafío</span></h2>
      </header>

      <div class="cat-grid">
        {categories.map((cat, index) => (
          <article class="cat-card tilt" data-animate={index % 2 ? 'right' : 'left'} data-delay={2 + index} style={`--cat: ${cat.color}`}>
            <div class="cat-icon"><span>{cat.icon}</span></div>
            <h3>{cat.title}</h3>
            <p>{cat.desc}</p>
            <div class="cat-code">
              <span class="c-dot"></span><span class="c-dot"></span><span class="c-dot"></span>
              <code>{cat.code}</code>
            </div>
            <span class="tilt-glare" aria-hidden="true"></span>
          </article>
        ))}
      </div>

      <a href="/categorias" class="link-more center" data-animate data-delay="6">VER CATEGORÍAS COMPLETAS →</a>
    </section>

    <!-- ═══════════════ CRONOGRAMA ═══════════════ -->
    <section id="cronograma" class="panel" data-accent-light={acc('cronograma').light} data-accent-dark={acc('cronograma').dark}>
      <header class="sec-head">
        <span class="sec-tag" data-animate="left">// AGENDA DEL DÍA</span>
        <h2 class="sec-title" data-animate data-delay="1">Horario de <span class="accent-text">Competencia</span></h2>
      </header>

      <div class="timeline" id="timeline">
        <div class="timeline-rail" aria-hidden="true"><span id="timeline-fill"></span></div>
        {agenda.map((item, index) => (
          <div class={`tl-entry ${index % 2 ? 'right' : 'left'}`} data-animate={index % 2 ? 'right' : 'left'} data-delay={index}>
            <div class="tl-node" style={`--node: ${item.color}`}><span></span></div>
            <div class="tl-card tilt" style={`--node: ${item.color}`}>
              <div class="tl-top">
                <span class="tl-time">{item.time}</span>
                <span class="tl-tag">{item.tag}</span>
              </div>
              <h3>{item.title}</h3>
              <p>{item.desc}</p>
              <span class="tilt-glare" aria-hidden="true"></span>
            </div>
          </div>
        ))}
      </div>

      <a href="/cronograma" class="link-more center" data-animate>CRONOGRAMA DETALLADO →</a>
    </section>

    <!-- ═══════════════ PREMIOS ═══════════════ -->
    <section id="premios" class="panel" data-accent-light={acc('premios').light} data-accent-dark={acc('premios').dark}>
      <div class="float-el" data-speed="0.2" style="top:14%; right:10%;">🏆</div>

      <header class="sec-head">
        <span class="sec-tag" data-animate="left">// PREMIACIÓN</span>
        <h2 class="sec-title" data-animate data-delay="1">Reconoci<span class="accent-text">mientos</span></h2>
      </header>

      <div class="podium">
        {premios.map((p, index) => (
          <div class={`podium-col ${p.h}`} data-animate={p.anim} data-delay={2 + index} style={`--medal: ${p.color}`}>
            <div class="podium-imgs">
              {p.imgs.map((img) => <img src={`/${img}`} alt={p.titulo} loading="lazy" />)}
            </div>
            <div class="podium-block tilt">
              <span class="podium-rank">{p.lugar}</span>
              <h3>{p.titulo}</h3>
              <p>{p.desc}</p>
              <span class="tilt-glare" aria-hidden="true"></span>
            </div>
          </div>
        ))}
      </div>

      <a href="/Premios" class="link-more center" data-animate>VER PREMIOS →</a>
    </section>

    <!-- ═══════════════ REGLAS ═══════════════ -->
    <section id="reglas" class="panel" data-accent-light={acc('reglas').light} data-accent-dark={acc('reglas').dark}>
      <header class="sec-head">
        <span class="sec-tag" data-animate="left">// REGLAMENTO</span>
        <h2 class="sec-title" data-animate data-delay="1">Reglas del <span class="accent-text">Juego</span></h2>
      </header>

      <div class="terminal" data-animate="left" data-delay="2">
        <div class="terminal-bar">
          <span class="t-dot r"></span><span class="t-dot y"></span><span class="t-dot g"></span>
          <span class="t-title">~ /devxtreme/rules.sh</span>
        </div>
        <div class="terminal-body">
          {rules.map((rule, index) => (
            <p class="t-line" data-animate="left" data-delay={3 + index}>
              <span class="t-num">[{String(index + 1).padStart(2, '0')}]</span> {rule}
            </p>
          ))}
          <p class="t-line t-ok" data-animate="left" data-delay={3 + rules.length}>
            <span class="prompt">$</span> ./ver_reglamento_completo <a href="/reglas" class="t-link">--full</a>
          </p>
        </div>
      </div>
    </section>

    <!-- ═══════════════ CTA FINAL ═══════════════ -->
    <section id="registro" class="panel cta-panel" data-accent-light={acc('registro').light} data-accent-dark={acc('registro').dark}>
      <h2 class="cta-title" data-animate="zoom">¿LISTO PARA<br /><span class="accent-text">COMPETIR</span>?</h2>
      <p class="cta-sub" data-animate data-delay="1">Equipos de 3. Cupos limitados. El cronómetro no espera.</p>
      <a href="/registro" target="_blank" class="btn btn-primary btn-xl magnetic" data-animate="zoom" data-delay="2">
        <span>REGISTRARSE AHORA →</span>
      </a>
    </section>

  </main>
</Layout>

<style>
  /* ════════════════ BASE / SECCIÓN ════════════════ */
  #landing {
    --sa: var(--orange);           /* accent de la sección activa (lo actualiza JS) */
    --sa-soft: color-mix(in srgb, var(--sa) 12%, transparent);
    position: relative;
    z-index: 10;
  }

  .panel {
    position: relative;
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 100px 24px;
    max-width: 1150px;
    margin: 0 auto;
    scroll-margin-top: 90px;
  }

  /* Separación amplia entre secciones: el tramo en negro dura más
     y la siguiente sección aparece de sorpresa desde la oscuridad */
  .panel + .panel { margin-top: 48vh; }
  .marquee + .panel { margin-top: 42vh; }
  @media (max-width: 640px) {
    .panel + .panel { margin-top: 36vh; }
    .marquee + .panel { margin-top: 30vh; }
  }

  /* halo de color que cambia por sección */
  .panel::before {
    content: "";
    position: absolute;
    inset: -10% -30%;
    background: radial-gradient(ellipse at 50% 40%, var(--sa-soft), transparent 65%);
    z-index: -1;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.8s ease;
    filter: blur(30px);
  }
  .panel.active::before { opacity: 1; }

  /* ════════════════ VELO ENTRE SECCIONES ════════════════ */
  /* Apagón: negro absoluto entre secciones; la opacidad la calcula el
     scroll frame a frame, así el fundido acompaña exactamente al gesto */
  #section-veil {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 55% 42% at 50% 50%, rgba(var(--accent-rgb), 0.10), rgba(0, 0, 0, 0) 62%),
      #000;
    opacity: 0;
    pointer-events: none;
    z-index: 800;
    will-change: opacity;
  }
  /* transición solo cuando se navega con los puntos (parpadeo) */
  #section-veil.nav-fade { transition: opacity 0.35s ease; }
  #veil-label {
    position: absolute;
    left: 50%; top: 50%;
    transform: translate(-50%, -50%);
    font-size: clamp(1.1rem, 5vw, 2.8rem);
    font-weight: 800;
    letter-spacing: 8px;
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--sa, var(--orange));
    text-shadow: 0 0 34px rgba(var(--accent-rgb), 0.55);
    opacity: 0;
    will-change: opacity, transform;
  }

  /* Foco que sigue al puntero, teñido con el acento de la sección */
  #cursor-glow {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: radial-gradient(540px circle at var(--mx, 50%) var(--my, 38%), var(--sa-soft), transparent 72%);
  }

  /* ════════════════ CANVAS PARTÍCULAS ════════════════ */
  #particles {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  /* ════════════════ PROGRESO SCROLL ════════════════ */
  .scroll-progress {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 3px;
    z-index: 2000;
    background: transparent;
  }
  #progress-bar {
    display: block;
    height: 100%;
    width: 100%;
    transform-origin: left;
    transform: scaleX(0);
    background: linear-gradient(90deg, var(--yellow), var(--orange), var(--red));
    box-shadow: 0 0 12px rgba(var(--accent-rgb), 0.6);
  }

  /* ════════════════ DOT NAV ════════════════ */
  .dot-nav {
    position: fixed;
    right: 22px; top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 14px;
    z-index: 500;
  }
  .dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    border: 2px solid var(--text-faint);
    background: transparent;
    position: relative;
    transition: all 0.3s ease;
  }
  .dot:hover, .dot.active {
    border-color: var(--sa, var(--orange));
    background: var(--sa, var(--orange));
    box-shadow: 0 0 10px var(--sa, var(--orange));
    transform: scale(1.25);
  }
  .dot-label {
    position: absolute;
    right: 22px; top: 50%;
    transform: translateY(-50%) translateX(6px);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    white-space: nowrap;
    color: var(--text-muted);
    background: var(--bg-card);
    border: 1px solid var(--border-accent);
    padding: 4px 10px;
    opacity: 0;
    pointer-events: none;
    transition: all 0.25s ease;
  }
  .dot:hover .dot-label { opacity: 1; transform: translateY(-50%) translateX(0); }
  @media (max-width: 900px) { .dot-nav { display: none; } }

  /* ════════════════ SCROLL REVEALS (REVERSIBLES) ════════════════ */
  [data-animate] {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s cubic-bezier(0.2, 0.7, 0.2, 1),
                transform 0.7s cubic-bezier(0.2, 0.7, 0.2, 1);
    transition-delay: 0s; /* salida inmediata al hacer scroll inverso */
  }
  [data-animate="left"]  { transform: translateX(-60px); }
  [data-animate="right"] { transform: translateX(60px); }
  [data-animate="zoom"]  { transform: translateY(20px) scale(0.94); }
  [data-animate].in-view {
    opacity: 1;
    transform: none;
    transition-delay: calc(var(--d, 0) * 90ms); /* entrada escalonada */
  }

  /* ════════════════ HERO ════════════════ */
  .hero { text-align: center; min-height: calc(100vh - 111px); }

  .hero-terminal {
    font-family: ui-monospace, 'Cascadia Code', Consolas, monospace;
    font-size: clamp(0.7rem, 2vw, 0.9rem);
    color: var(--text-muted);
    margin-bottom: 18px;
    min-height: 1.4em;
  }
  .prompt { color: var(--orange); font-weight: 700; }
  .cursor { animation: blink 0.9s step-end infinite; color: var(--orange); }
  @keyframes blink { 50% { opacity: 0; } }

  .hero-title {
    font-size: clamp(2.2rem, 11vw, 8rem);
    font-weight: 800;
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: -1px;
    margin-bottom: 24px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: baseline;
    gap: 0 0.25em;
  }
  .glitch-wrap, .hero-version { display: inline-flex; }
  .hero-version .letter {
    background: linear-gradient(180deg, var(--red), var(--orange));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .letter {
    display: inline-block;
    background: linear-gradient(90deg, var(--yellow), var(--orange), var(--red));
    -webkit-background-clip: text;
