---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';

const stats = [
  { label: "FECHA", value: "15 MAYO" },
  { label: "INICIO", value: "09:00" },
  { label: "CIERRE", value: "14:00" },
  { label: "DURACIÓN", value: "4 HRS" },
];
---

<Layout title="DevXtreme">
  

    <main>
      
      <div class="title">
        <span>DEVXTREME 3.0</span>
     
      </div>
      

      <p class="description">
        Demuestra tu dominio del código. El evento dura 4 horas: inauguración, explicación del entorno y una
        competencia práctica en HackerRank con clasificación por puntos.
      </p>

      <div class="stats">
        {stats.map((item) => (
          <div class="card">
            <span>{item.label}</span>
            <h3>{item.value}</h3>
          </div>
        ))}
      </div>

      

      <div class="buttons">
        <a href="/Explorar" class="btn"><span>EXPLORAR EVENTO</span></a>
        <a href="/cronograma" class="btn"><span>CRONOGRAMA</span></a>
        <a href="/categorias" class="btn"><span>CATEGORÍAS</span></a>
        <a href="/reglas" class="btn"><span>REGLAS</span></a>
        <a href="https://docs.google.com/forms/d/e/1FAIpQLSf4WLvdGXD1bmyWqee9N5IfMA6szlF5eUniLZvVFHSRzQWXCw/viewform" target="_blank" class="btn"><span>REGISTRARSE</span></a>
      </div>


      
    </main>
</Layout>

<style>
  /* Aquí solo dejamos estilos que NO sean globales */

  main {
    padding: 60px 20px;
    text-align: center;
    position: relative;
    z-index: 10; /* Para que esté sobre el grid */
  }
  
  .title span {
    display: block;
    font-size: clamp(3.5rem, 10vw, 8rem);
    font-weight: 800;
    line-height: 0.9;
    background: linear-gradient(90deg, var(--yellow), var(--orange), var(--red));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .version { margin: 20px 0; font-size: 1.2rem; letter-spacing: 8px; color: #888; }

 .description { 
    max-width: 650px; 
    margin: 0 auto 50px; 
    line-height: 1.8; 
    color: #e66e00; 
    font-weight: 500;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    max-width: 700px;
    margin: 0 auto 60px;
  }

  .card {
    background: white;
    border: 1px solid rgba(255, 122, 0, 0.3);
    padding: 20px;
  }

  .card span { font-size: 0.7rem; letter-spacing: 2px; color: #999; }
  .card h3 { font-size: 1.5rem; color: var(--orange); margin-top: 5px; }

  .buttons {
    display: flex;
    justify-content: center;
    gap: 15px;
    flex-wrap: wrap; 
    max-width: 1200px;
    margin: 0 auto;
  }

  .btn {
    min-width: 200px;
    padding: 15px 25px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 1px;
    border: 2px solid var(--orange);
    transition: 0.3s;
    background: white; 
    display: inline-block;
  }

  .btn span {
    background: linear-gradient(90deg, var(--yellow), var(--orange), var(--red));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(255, 122, 0, 0.15);
  }

  @media (max-width: 800px) {
    .stats { grid-template-columns: repeat(2, 1fr); }
    .btn { width: 45%; }
  }
</style>