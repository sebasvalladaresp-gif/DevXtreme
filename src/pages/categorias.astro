---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Categorías - DevXtreme 3.0">
  <section class="categories-section">
    <div class="header-content reveal">
      <span class="eyebrow">// NIVELES DE DIFICULTAD</span>
      <h1 class="page-title">Elige tu <span class="gradient-text">Categoría</span></h1>
      <p class="page-subtitle">Tres niveles de dificultad. Diseñados para poner a prueba tu lógica sin importar el semestre en el que te encuentres.</p>
    </div>

    <div class="cat-grid">

      <!-- BÁSICA -->
      <div class="cat-card reveal-zoom" style="--delay: 0.1s; --cat-color: var(--green);">
        <div class="cat-glow"></div>
        <div class="cat-inner">
          <div class="cat-level">NIVEL 01</div>
          <h2 class="cat-name">Básica</h2>
          <p class="cat-desc">Fundamentos de programación, estructuras de control, bucles y lógica básica.</p>
          <div class="cat-reqs">
            <strong>REQUISITO:</strong>
            <span>1ero a 2do Semestre</span>
          </div>
          <div class="cat-code">
            <span class="code-comment">// Ejemplo esperado</span>
            <span class="code-line">print("Hello World!")</span>
            <span class="code-line">for i in range(10):</span>
            <span class="code-line">&nbsp;&nbsp;solve()</span>
          </div>
        </div>
      </div>

      <!-- INTERMEDIA -->
      <div class="cat-card reveal-zoom" style="--delay: 0.2s; --cat-color: var(--orange-light);">
        <div class="cat-glow"></div>
        <div class="cat-inner">
          <div class="cat-level">NIVEL 02</div>
          <h2 class="cat-name">Intermedia</h2>
          <p class="cat-desc">Estructuras de datos (pilas, colas, listas), algoritmos de búsqueda y ordenamiento.</p>
          <div class="cat-reqs">
            <strong>REQUISITO:</strong>
            <span>3ro a 4to Semestre</span>
          </div>
          <div class="cat-code">
            <span class="code-comment">// Ejemplo esperado</span>
            <span class="code-line">vector&lt;int&gt; v;</span>
            <span class="code-line">sort(v.begin(), v.end());</span>
            <span class="code-line">binary_search(v, target);</span>
          </div>
        </div>
      </div>

      <!-- AVANZADA -->
      <div class="cat-card reveal-zoom" style="--delay: 0.3s; --cat-color: var(--orange);">
        <div class="cat-glow"></div>
        <div class="cat-inner">
          <div class="cat-level">NIVEL 03</div>
          <h2 class="cat-name">Avanzada</h2>
          <p class="cat-desc">Grafos, programación dinámica, árboles y algoritmos de optimización complejos.</p>
          <div class="cat-reqs">
            <strong>REQUISITO:</strong>
            <span>5to Semestre en adelante</span>
          </div>
          <div class="cat-code">
            <span class="code-comment">// Ejemplo esperado</span>
            <span class="code-line">dfs(node, parent);</span>
            <span class="code-line">dp[i][w] = max(dp...);</span>
            <span class="code-line">Dijkstra(graph, start);</span>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  .categories-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 20px 100px;
  }

  .header-content {
    text-align: center;
    margin-bottom: 80px;
  }

  .eyebrow {
    font-family: monospace;
    color: var(--green);
    letter-spacing: 4px;
    font-size: 0.8rem;
    font-weight: 700;
    display: block;
    margin-bottom: 16px;
  }

  .page-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 1;
    margin-bottom: 20px;
    letter-spacing: -1px;
  }

  .gradient-text {
    background: linear-gradient(to right, var(--green), var(--orange));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  /* ── GRID ── */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .cat-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 24px;
    position: relative;
    overflow: hidden;
    backdrop-filter: var(--glass-blur);
    transition: transform 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
  }

  .cat-card:hover {
    transform: translateY(-10px);
    border-color: var(--cat-color);
    box-shadow: 0 20px 40px rgba(0,0,0,0.5), 0 0 20px rgba(255,255,255,0.05);
  }

  .cat-glow {
    position: absolute;
    top: 0; left: 0; right: 0; height: 150px;
    background: radial-gradient(ellipse at top, var(--cat-color) 0%, transparent 70%);
    opacity: 0.15;
    transition: opacity 0.4s ease;
  }
  .cat-card:hover .cat-glow { opacity: 0.3; }

  .cat-inner {
    padding: 40px 30px;
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .cat-level {
    font-family: monospace;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--cat-color);
    letter-spacing: 2px;
    margin-bottom: 16px;
  }

  .cat-name {
    font-size: 2.2rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 16px;
    letter-spacing: -0.5px;
  }

  .cat-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 30px;
    flex-grow: 1;
  }

  .cat-reqs {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 24px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .cat-reqs strong {
    font-family: monospace;
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 1px;
  }
  .cat-reqs span {
    font-size: 0.9rem;
    font-weight: 600;
    color: #fff;
  }

  .cat-code {
    background: #050505;
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 16px;
    font-family: monospace;
    font-size: 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .code-comment { color: var(--text-muted); }
  .code-line { color: var(--cat-color); }

  @media (max-width: 900px) {
    .cat-grid { grid-template-columns: 1fr; max-width: 500px; margin: 0 auto; }
  }
</style>