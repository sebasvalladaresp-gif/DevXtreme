---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Créditos - DevXtreme 3.0">
  <section class="credits-section">
    <div class="header-content reveal">
      <span class="eyebrow">// BEHIND THE SCENES</span>
      <h1 class="page-title">Equipo <span class="gradient-text">Fundador</span></h1>
      <p class="page-subtitle">Las mentes detrás de DevXtreme. Agradecimiento especial a quienes hicieron posible este ecosistema de desarrollo competitivo.</p>
    </div>

    <div class="founders-grid">

      <!-- Víctor Echeverría -->
      <div class="founder-card reveal-zoom" style="--delay: 0.1s">
        <div class="founder-image-wrapper">
          <div class="founder-glow"></div>
          <img src="/VictorEcheverria.jpeg" alt="Víctor Echeverría" class="founder-image" />
          <div class="founder-ring"></div>
        </div>
        <div class="founder-info">
          <h3>Víctor Echeverría</h3>
          <p class="founder-role">Fundador DevXtreme</p>
        </div>
      </div>

      <!-- Adrián Urresta -->
      <div class="founder-card reveal-zoom" style="--delay: 0.2s">
        <div class="founder-image-wrapper">
          <div class="founder-glow"></div>
          <img src="/AdrianUrresta.jpeg" alt="Adrián Urresta" class="founder-image" />
          <div class="founder-ring"></div>
        </div>
        <div class="founder-info">
          <h3>Adrián Urresta</h3>
          <p class="founder-role">Creador Página Web / Chair CS</p>
          <a href="https://www.instagram.com/adrx_sanz" target="_blank" class="founder-ig">@adrx_sanz</a>
        </div>
      </div>

      <!-- Francisco Valladares -->
      <div class="founder-card reveal-zoom" style="--delay: 0.3s">
        <div class="founder-image-wrapper">
          <div class="founder-glow"></div>
          <img src="/FranciscoValladares.jpeg" alt="Francisco Valladares" class="founder-image" />
          <div class="founder-ring"></div>
        </div>
        <div class="founder-info">
          <h3>Francisco Valladares</h3>
          <p class="founder-role">Creador Página Web / Colaborador</p>
        </div>
      </div>

      <!-- Dario López -->
      <div class="founder-card reveal-zoom" style="--delay: 0.4s">
        <div class="founder-image-wrapper">
          <div class="founder-glow"></div>
          <img src="/Darlopc.png" alt="Dario López" class="founder-image" />
          <div class="founder-ring"></div>
        </div>
        <div class="founder-info">
          <h3>Dario López</h3>
          <p class="founder-role">Presidente Club Programación</p>
          <a href="https://www.instagram.com/darlopez05/" target="_blank" class="founder-ig">@darlopez05</a>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  .credits-section {
    max-width: 1000px;
    margin: 0 auto;
    padding: 80px 20px 100px;
  }

  .header-content { text-align: center; margin-bottom: 80px; }
  .eyebrow { font-family: monospace; color: var(--orange); letter-spacing: 4px; font-size: 0.8rem; font-weight: 700; display: block; margin-bottom: 16px; }
  .page-title { font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 700; line-height: 1; margin-bottom: 20px; letter-spacing: -1px; }
  .gradient-text { background: linear-gradient(to right, var(--orange), var(--orange-light)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .page-subtitle { font-size: 1.1rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto; line-height: 1.6; }

  /* ── FOUNDERS GRID ── */
  .founders-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
  }

  .founder-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: transparent;
  }

  .founder-image-wrapper {
    position: relative;
    width: 160px;
    height: 160px;
    margin-bottom: 24px;
    border-radius: 50%;
  }

  .founder-glow {
    position: absolute;
    inset: -20px;
    background: radial-gradient(circle, var(--orange-glow) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.5s ease;
    border-radius: 50%;
    z-index: 0;
  }
  .founder-card:hover .founder-glow { opacity: 1; }

  .founder-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    position: relative;
    z-index: 2;
    filter: grayscale(80%) contrast(1.2);
    transition: filter 0.5s ease, transform 0.5s ease;
  }
  .founder-card:hover .founder-image {
    filter: grayscale(0%) contrast(1.1);
    transform: scale(1.05);
  }

  .founder-ring {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, transparent 0 270deg, var(--orange) 360deg);
    z-index: 3;
    opacity: 0.3;
    animation: spinRing 4s linear infinite;
  }
  .founder-card:hover .founder-ring { opacity: 1; animation-duration: 2s; }

  @keyframes spinRing { 100% { transform: rotate(360deg); } }

  .founder-info h3 {
    font-size: 1.2rem;
    color: #fff;
    margin-bottom: 6px;
    font-weight: 600;
  }

  .founder-role {
    font-family: monospace;
    font-size: 0.75rem;
    color: var(--text-muted);
    line-height: 1.4;
    margin-bottom: 8px;
  }

  .founder-ig {
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--orange);
    text-decoration: none;
    border-bottom: 1px dashed transparent;
    transition: border-color 0.3s ease, color 0.3s ease;
  }
  .founder-ig:hover {
    color: #fff;
    border-color: #fff;
  }

  @media (max-width: 900px) {
    .founders-grid { grid-template-columns: repeat(2, 1fr); gap: 40px; }
  }
  @media (max-width: 500px) {
    .founders-grid { grid-template-columns: 1fr; gap: 50px; }
  }
</style>