---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto - DevXtreme">
  <div class="main-container">

    <!-- ══════════════════════════════
         FOUNDERS MENTION
    ═══════════════════════════════ -->
    <div class="founders-section">
      <div class="founders-header">
        <span class="founders-prefix reveal">// MENCIÓN ESPECIAL</span>
        <h2 class="founders-title reveal delay-1">Fundadores &amp; <span class="accent neon-title">Organizadores</span></h2>
        <p class="founders-description reveal delay-2">
          Estos visionarios hicieron posible DevXtreme 3.0. Su dedicación y pasión por la programación impulsan este evento.
        </p>
      </div>

      <div class="founders-grid">
        <!-- Víctor Echeverría -->
        <div class="founder-card reveal-zoom" style="--delay: 0.18s">
          <div class="founder-image-wrapper">
            <img src="/VictorEcheverria.jpeg" alt="Víctor Echeverría" class="founder-image" />
            <div class="founder-overlay"></div>
          </div>
          <div class="founder-info">
            <h3>Víctor Echeverría</h3>
            <p class="founder-role">Fundador DevXtreme</p>
          </div>
        </div>

        <!-- Adrián Urresta -->
        <div class="founder-card reveal-zoom" style="--delay: 0.26s">
          <div class="founder-image-wrapper">
            <img src="/AdrianUrresta.jpeg" alt="Adrián Urresta" class="founder-image" />
            <div class="founder-overlay"></div>
          </div>
          <div class="founder-info">
            <h3>Adrián Urresta</h3>
            <p class="founder-role">Creador Página Web</p>
            <p class="founder-role">Chair CS 2026</p>
          </div>
        </div>

        <!-- Francisco Valladares -->
        <div class="founder-card reveal-zoom" style="--delay: 0.34s">
          <div class="founder-image-wrapper">
            <img src="/FranciscoValladares.jpeg" alt="Francisco Valladares" class="founder-image" />
            <div class="founder-overlay"></div>
          </div>
          <div class="founder-info">
            <h3>Francisco Valladares</h3>
            <p class="founder-role">Creador Página Web </p>
            <p class="founder-role">Colaborador</p>

          </div>
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════
         CONTACTS
    ═══════════════════════════════ -->

    <footer class="site-footer reveal delay-3">
      <p>Somos parte de <span class="highlight">IEEE</span> y de la <span class="highlight">UTN</span>.</p>
      <p>Ibarra - Ecuador</p>
      <p class="copyright">&copy; Todos los derechos reservados 2026</p>
    </footer>

  </div>
</Layout>

<style>
  .main-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: clamp(80px, 10vh, 120px) 20px 40px;
    font-family: 'Orbitron', sans-serif;
  }

  /* ── FOOTER ── */
  .site-footer {
    text-align: center;
    color: var(--footer-text);
    font-size: clamp(0.75rem, 1.5vw + 0.3rem, 0.85rem);
    line-height: 1.6;
    margin-top: 40px;
    padding: 20px;
    border-top: 1px solid var(--footer-border);
    width: 100%;
    max-width: 600px;
    transition: color 0.4s ease, border-color 0.4s ease;
  }

  .site-footer p { margin: 5px 0; }

  .site-footer .highlight {
    color: var(--cyan);
    font-weight: 700;
  }

  .site-footer .copyright {
    margin-top: 15px;
    font-size: clamp(0.65rem, 1.2vw + 0.2rem, 0.75rem);
    color: var(--text-faint);
    letter-spacing: 1px;
    font-family: system-ui, -apple-system, sans-serif;
  }

  /* ══════════════════════════════════
     FOUNDERS SECTION
  ══════════════════════════════════ */
  .founders-section {
    width: 100%;
    max-width: 1000px;
    margin-bottom: 70px;
    padding: 0 20px;
  }

  .founders-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .founders-prefix {
    display: inline-block;
    color: var(--cyan);
    font-family: monospace;
    font-weight: 800;
    letter-spacing: 3px;
    font-size: 0.85rem;
    margin-bottom: 12px;
  }

  .founders-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1.15;
    margin: 10px 0 20px;
    transition: color 0.4s ease;
  }

  .founders-title .accent {
    background: linear-gradient(90deg, var(--cyan), var(--magenta));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .founders-description {
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
    font-size: clamp(0.85rem, 2vw, 0.95rem);
    transition: color 0.4s ease;
  }

  /* ── FOUNDERS GRID ── */
  .founders-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: clamp(24px, 4vw, 36px);
    max-width: 800px;
    margin: 0 auto;
  }

  /* ── FOUNDER CARD ── */
  .founder-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .founder-card:hover {
    transform: translateY(-8px) scale(1.02);
  }

  /* ── CIRCULAR IMAGE WRAPPER ── */
  .founder-image-wrapper {
    position: relative;
    width: clamp(140px, 25vw, 180px);
    height: clamp(140px, 25vw, 180px);
    margin-bottom: 20px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--border-accent);
    background: var(--bg-card);
    transition: all 0.4s ease;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  [data-theme="dark"] .founder-image-wrapper {
    border-color: rgba(0, 212, 255, 0.4);
    box-shadow: 0 8px 32px rgba(0, 212, 255, 0.1), 0 0 30px rgba(0, 212, 255, 0.05);
  }

  .founder-card:hover .founder-image-wrapper {
    border-color: var(--cyan);
    box-shadow: 0 12px 40px rgba(0, 212, 255, 0.25);
  }

  [data-theme="dark"] .founder-card:hover .founder-image-wrapper {
    box-shadow: 0 12px 50px rgba(0, 212, 255, 0.3), 0 0 40px rgba(255, 0, 110, 0.1);
  }

  .founder-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease, filter 0.4s ease;
  }

  .founder-card:hover .founder-image {
    transform: scale(1.08);
    filter: brightness(1.1);
  }

  [data-theme="dark"] .founder-card:hover .founder-image {
    filter: brightness(1.2);
  }

  .founder-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0, 212, 255, 0.1), rgba(255, 0, 110, 0.05));
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .founder-card:hover .founder-overlay {
    opacity: 0.8;
  }

  /* ── FOUNDER INFO ── */
  .founder-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .founder-info h3 {
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    font-weight: 800;
    color: var(--text-card-title);
    margin: 0;
    transition: color 0.4s ease;
    letter-spacing: 0.5px;
  }

  .founder-role {
    font-size: clamp(0.8rem, 1.8vw, 0.9rem);
    color: var(--cyan);
    font-weight: 600;
    margin: 0;
    letter-spacing: 1px;
    font-family: monospace;
    transition: color 0.4s ease;
  }

  /* ══════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════ */
  @media (max-width: 768px) {
    .founders-section {
      margin-bottom: 60px;
      padding: 0 16px;
    }

    .founders-title {
      font-size: 1.8rem;
    }

    .founders-grid {
      gap: 20px;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    }

    .founder-image-wrapper {
      width: clamp(120px, 28vw, 160px);
      height: clamp(120px, 28vw, 160px);
      margin-bottom: 16px;
    }
  }

  @media (max-width: 480px) {
    .founders-section {
      margin-bottom: 50px;
      padding: 0 12px;
    }

    .founders-grid {
      grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
      gap: 16px;
    }

    .founder-info h3 {
      font-size: 0.95rem;
    }

    .founder-role {
      font-size: 0.75rem;
    }
  }
</style>