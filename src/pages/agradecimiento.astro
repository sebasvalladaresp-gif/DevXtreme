---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto - DevXtreme">
  <div class="main-container">
    
    <header class="top-bar">
      <span class="brand">DEVXTREME</span>
      <span class="date">15 • MAYO • 2026</span>
    </header>

    <main class="card">
      <div class="card-content">
        <h2>Creador: <span>Sebastián Valladares</span></h2>
        <h2>Colaborador: <span>Adrian Urresta</span></h2>
        
        <p class="label">Gmail / Contacto</p>
        <div class="email-list">
          <div class="email-item">
            <span class="icon-email">✉</span> f82997419@gmail.com
          </div>
          <div class="email-item">
            <span class="icon-email">✉</span> xdadrianlol@gmail.com
          </div>
        </div>
        
        <div class="bottom-logo-container">
          <img src="/Pandilla.jpeg" alt="Logo Pandilla" class="mini-logo" />
        </div>
      </div>
    </main>

  </div>
</Layout>

<style>
  /* Contenedor principal: Centra todo el contenido */
  .main-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 120px 20px 60px; /* Padding extra arriba para la flecha naranja */
    font-family: 'Orbitron', sans-serif;
  }

  /* Barra superior estilo terminal/tech */
  .top-bar {
    width: 100%;
    max-width: 500px;
    display: flex;
    justify-content: space-between;
    padding: 12px 25px;
    background: #0a0a0a;
    color: #ffcc00; /* Amarillo tech */
    border-radius: 15px 15px 0 0;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 2px;
    border: 1px solid rgba(255, 122, 0, 0.3);
    border-bottom: none;
  }

  /* Tarjeta blanca minimalista */
  .card {
    width: 100%;
    max-width: 500px;
    background: #ffffff;
    border: 1px solid rgba(255, 122, 0, 0.2);
    border-top: none;
    padding: 50px 40px;
    border-radius: 0 0 15px 15px;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.08);
    position: relative;
  }

  /* Estilos de texto */
  .card-content h2 {
    font-size: 1.3rem;
    margin-bottom: 15px;
    color: #333;
    line-height: 1.4;
  }

  .card-content h2 span {
    color: #ff7a00; /* Naranja corporativo */
    font-weight: 800;
  }

  .label {
    font-size: 0.65rem;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 3px;
    margin: 35px 0 15px;
    border-bottom: 1px solid #f0f0f0;
    padding-bottom: 8px;
  }

  .email-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .email-item {
    font-size: 0.9rem;
    color: #444;
    font-weight: 600;
    word-break: break-all; /* Protege el diseño en móviles pequeños */
    display: flex;
    align-items: center;
  }

  .icon-email {
    color: #ff7a00;
    margin-right: 10px;
    font-size: 1.1rem;
  }

  /* Contenedor del logo inferior */
  .bottom-logo-container {
    margin-top: 88px;
    display: flex;
    justify-content: center;
  }

  .mini-logo {
    height: 70px;
    width: auto;
    border-radius: 12px;
    transition: transform 0.3s ease;
    filter: drop-shadow(0 5px 10px rgba(0,0,0,0.1));
  }

  .mini-logo:hover {
    transform: scale(1.05);
  }

  /* =========================
     MEDIA QUERIES (MÓVIL)
  ========================== */
  @media (max-width: 600px) {
    .main-container {
      padding-top: 140px; /* Más espacio para la flecha en iPhone/Pixel */
    }

    .top-bar {
      padding: 10px 15px;
      font-size: 0.65rem;
    }

    .card {
      padding: 35px 20px;
      width: 95%; /* Que ocupe casi todo el ancho */
    }

    .card-content h2 {
      font-size: 1.05rem;
    }

    .email-item {
      font-size: 0.8rem;
    }
  }
</style>