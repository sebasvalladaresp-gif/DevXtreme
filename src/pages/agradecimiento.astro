---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto - DevXtreme">
  <div class="main-container">

    <div class="cards-wrapper">

      <article class="card-container reveal-zoom" style="--delay: 0.12s">
        <header class="top-bar">
          <span class="brand">DEVXTREME</span>
          <span class="date">CREADOR</span>
        </header>
        <main class="card">
          <div class="card-content">
            <div class="whatsapp-profile">
              <div class="img-ring">
                <img src="https://ui-avatars.com/api/?name=Sebastian+Valladares&background=ff7a00&color=fff&size=150"
                     alt="Sebastián Valladares" class="profile-img" />
              </div>
              <div class="profile-info">
                <h2>Sebastián Valladares</h2>
                <p class="role">Miembro IEEE UTN</p>
              </div>
            </div>

            <div class="contact-actions">
              <a href="https://wa.me/593969386165" target="_blank" rel="noopener noreferrer"
                 class="action-btn wa-btn" title="Contactar por WhatsApp">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
                </svg>
              </a>
            </div>

            <p class="label">Correo Electrónico</p>
            <div class="email-list">
              <div class="email-item">
                <span class="icon-email">✉</span>
                <a href="mailto:f82997419@gmail.com" class="email-link">f82997419@gmail.com</a>
              </div>
            </div>
          </div>
        </main>
      </article>

      <article class="card-container reveal-zoom" style="--delay: 0.24s">
        <header class="top-bar">
          <span class="brand">DEVXTREME</span>
          <span class="date">COLABORADOR</span>
        </header>
        <main class="card">
          <div class="card-content">
            <div class="whatsapp-profile">
              <div class="img-ring">
                <img src="https://ui-avatars.com/api/?name=Adrian+Urresta&background=0a0a0a&color=ffcc00&size=150"
                     alt="Adrián Urresta" class="profile-img" />
              </div>
              <div class="profile-info">
                <h2>Adrián Urresta</h2>
                <p class="role">Presidente IEEE CS Student Branch UTN</p>
              </div>
            </div>

            <div class="contact-actions">
              <a href="https://wa.me/593978640544" target="_blank" rel="noopener noreferrer"
                 class="action-btn wa-btn" title="Contactar por WhatsApp">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
                </svg>
              </a>
            </div>

            <p class="label">Correo Electrónico</p>
            <div class="email-list">
              <div class="email-item">
                <span class="icon-email">✉</span>
                <a href="mailto:laurrestas@utn.edu.ec" class="email-link">laurrestas@utn.edu.ec</a>
              </div>
            </div>
          </div>
        </main>
      </article>

    </div>

    <footer class="site-footer reveal delay-3">
      <p>Somos parte de <span class="highlight">IEEE</span> y de la <span class="highlight">UTN</span>.</p>
      <p>Ibarra - Ecuador</p>
      <p class="copyright">&copy; Todos los derechos reservados 2026</p>
    </footer>

  </div>
</Layout>

<style>
  .main-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: clamp(80px, 10vh, 120px) 20px 40px;
    font-family: 'Orbitron', sans-serif;
  }

  .cards-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(20px, 4vw, 40px);
    justify-content: center;
    width: 100%;
    max-width: 1000px;
    margin-bottom: 50px;
  }

  .card-container {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 400px;
    flex: 1 1 320px;
    transition: transform 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .card-container:hover { transform: translateY(-6px); }

  /* ── TOP BAR ── */
  .top-bar {
    width: 100%;
    display: flex;
    justify-content: space-between;
    padding: 12px 25px;
    background: #0a0a0a;
    color: #ffcc00;
    border-radius: 15px 15px 0 0;
    font-size: clamp(0.65rem, 2vw, 0.75rem);
    font-weight: 700;
    letter-spacing: 2px;
    border: 1px solid rgba(255, 122, 0, 0.3);
    border-bottom: none;
    transition: background 0.4s ease;
  }

  [data-theme="dark"] .top-bar {
    background: #050508;
    border-color: rgba(255, 122, 0, 0.5);
  }

  /* ── CARD BODY ── */
  .card {
    width: 100%;
    background: var(--bg-card);
    border: 1px solid var(--profile-border);
    border-top: none;
    padding: clamp(25px, 5vw, 40px) clamp(20px, 4vw, 30px);
    border-radius: 0 0 15px 15px;
    box-shadow: var(--shadow-card);
    height: 100%;
    transition: background 0.4s ease, box-shadow 0.4s ease;
  }

  /* ── PROFILE ── */
  .whatsapp-profile {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: clamp(15px, 3vw, 25px);
  }

  /* Animated ring around avatar */
  .img-ring {
    padding: 4px;
    border-radius: 50%;
    background: conic-gradient(var(--yellow), var(--orange), var(--red), var(--orange), var(--yellow));
    animation: ringRotate 4s linear infinite;
    margin-bottom: 15px;
  }

  @keyframes ringRotate {
    to { filter: hue-rotate(360deg); }
  }

  .profile-img {
    width: clamp(80px, 15vw, 100px);
    height: clamp(80px, 15vw, 100px);
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--bg-card);
    display: block;
    transition: border-color 0.4s ease;
  }

  .profile-info h2 {
    font-size: clamp(1.1rem, 2.5vw + 0.5rem, 1.4rem);
    color: var(--text-card-title);
    margin: 0 0 8px;
    font-weight: 800;
    transition: color 0.4s ease;
  }

  .profile-info .role {
    font-size: clamp(0.75rem, 1.5vw + 0.3rem, 0.85rem);
    color: var(--orange);
    font-weight: 600;
    margin: 0;
    line-height: 1.4;
    letter-spacing: 1px;
    font-family: system-ui, -apple-system, sans-serif;
  }

  /* ── CONTACT ACTIONS ── */
  .contact-actions {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: clamp(20px, 4vw, 30px);
    padding-bottom: clamp(15px, 3vw, 25px);
    border-bottom: 1px solid var(--contact-divider);
    transition: border-color 0.4s ease;
  }

  .action-btn {
    background: var(--action-bg);
    color: var(--action-color);
    border: none;
    border-radius: 50%;
    width: clamp(45px, 8vw, 50px);
    height: clamp(45px, 8vw, 50px);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    text-decoration: none;
  }

  .action-btn svg {
    width: clamp(20px, 4vw, 24px);
    height: clamp(20px, 4vw, 24px);
  }

  .wa-btn {
    background: var(--wa-bg);
    color: var(--wa-color);
  }

  .wa-btn:hover {
    background: #25D366;
    color: #ffffff;
    transform: translateY(-4px) scale(1.1);
    box-shadow: 0 8px 16px rgba(37, 211, 102, 0.4);
  }

  /* ── EMAIL ── */
  .label {
    font-size: clamp(0.6rem, 1.5vw + 0.1rem, 0.65rem);
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 3px;
    margin: 0 0 15px;
    transition: color 0.4s ease;
  }

  .email-list { display: flex; flex-direction: column; gap: 12px; }

  .email-item {
    font-size: clamp(0.8rem, 1.8vw + 0.2rem, 0.9rem);
    color: var(--email-text);
    font-weight: 600;
    word-break: break-all;
    display: flex;
    align-items: center;
    background: var(--bg-email);
    padding: clamp(8px, 2vw, 10px) clamp(10px, 2vw, 15px);
    border-radius: 8px;
    font-family: system-ui, -apple-system, sans-serif;
    border: 1px solid var(--border-default);
    transition: background 0.4s ease, border-color 0.3s ease;
  }

  .email-item:hover { border-color: var(--orange); }

  .icon-email {
    color: var(--orange);
    margin-right: 10px;
    font-size: clamp(1rem, 2vw + 0.5rem, 1.1rem);
  }

  .email-link {
    color: var(--email-text);
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .email-link:hover { color: var(--orange); }

  /* ── FOOTER ── */
  .site-footer {
    text-align: center;
    color: var(--footer-text);
    font-size: clamp(0.75rem, 1.5vw + 0.3rem, 0.85rem);
    line-height: 1.6;
    margin-top: auto;
    padding: 20px;
    border-top: 1px solid var(--footer-border);
    width: 100%;
    max-width: 600px;
    transition: color 0.4s ease, border-color 0.4s ease;
  }

  .site-footer p { margin: 5px 0; }

  .site-footer .highlight {
    color: var(--orange);
    font-weight: 700;
  }

  .site-footer .copyright {
    margin-top: 15px;
    font-size: clamp(0.65rem, 1.2vw + 0.2rem, 0.75rem);
    color: var(--text-faint);
    letter-spacing: 1px;
    font-family: system-ui, -apple-system, sans-serif;
  }
</style>