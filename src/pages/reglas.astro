---
import Layout from '../layouts/Layout.astro';

const rules = [
  { id: 'SYS.REQ.01', title: 'EQUIPOS', text: 'De 3 integrantes por equipo. Cada uno con su propia laptop o máquina del laboratorio.', color: 'var(--green)', alert: false },
  { id: 'SYS.ERR.01', title: 'SIN COMUNICACIÓN', text: 'No se permite pasar información entre equipos durante la competencia.', color: 'var(--orange)', alert: true },
  { id: 'SYS.CRT.01', title: 'COPIA PROHIBIDA', text: 'Copy-paste prohibido. El código debe ser tuyo. Detección = descalificación inmediata.', color: '#ff3366', alert: true },
  { id: 'SYS.REQ.02', title: 'IA PERMITIDA', text: 'Puedes consultar IA como apoyo. No está permitido copiar soluciones completas.', color: 'var(--green)', alert: false },
  { id: 'SYS.INF.01', title: 'PLATAFORMA', text: 'HackerRank. Se puede programar en cualquier lenguaje soportado por la plataforma.', color: 'var(--orange-light)', alert: false },
  { id: 'SYS.INF.02', title: 'IDIOMA', text: 'Los ejercicios resueltos en inglés recibirán mayor puntuación cuando aplique.', color: 'var(--green)', alert: false },
  { id: 'SYS.INF.03', title: 'RANKING', text: 'Puntuación basada en dificultad y velocidad de envío. Gana quien obtenga el mejor score.', color: 'var(--orange-light)', alert: false },
  { id: 'SYS.LOC.01', title: 'LUGAR Y HORA', text: 'FICA Labs #1, #3 y #4. 15 de Mayo, 09:00 a 14:00.', color: 'var(--green)', alert: false },
];

const awards = [
  { rank: '1°', title: 'Primer lugar', prize: '3 Trofeos + Producto IEEE + Llavero Pingüino 🐧', color: 'var(--orange)' },
  { rank: '2°', title: 'Segundo lugar', prize: 'Producto IEEE + Pingüino Linux 🐧', color: 'var(--text-secondary)' },
  { rank: '3°', title: 'Tercer lugar', prize: 'Pingüino Linux 🐧', color: 'var(--green)' }
];
---

<Layout title="Reglas - DevXtreme 3.0">
  <section class="rules-page">
    <div class="header-content reveal">
      <span class="eyebrow">// DIRECTIVAS DEL SISTEMA</span>
      <h1 class="page-title">Reglas & <span class="gradient-text">Premios</span></h1>
      <p class="page-subtitle">Conoce las normativas del evento y los incentivos para los mejores desarrolladores.</p>
    </div>

    <div class="rules-grid">
      
      <!-- RULES TERMINAL -->
      <div class="rules-terminal reveal-left" style="--delay: 0.1s">
        <div class="terminal-header">
          <div class="window-controls">
            <span></span><span></span><span></span>
          </div>
          <div class="terminal-title">~/devxtreme/rules.sh</div>
        </div>
        <div class="terminal-content">
          {rules.map((rule, i) => (
            <div class={`rule-item ${rule.alert ? 'rule-alert' : ''}`} style={`--rule-color: ${rule.color}`}>
              <div class="rule-id">{rule.id}</div>
              <div class="rule-body">
                <h3 class="rule-title">{rule.title}</h3>
                <p class="rule-text">{rule.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- AWARDS BENTO -->
      <div class="awards-container">
        
        {awards.map((award, i) => (
          <div class="award-card reveal-right" style={`--delay: ${0.2 + i * 0.1}s; --award-color: ${award.color};`}>
            <div class="award-glow"></div>
            <div class="award-rank">{award.rank}</div>
            <div class="award-info">
              <h3>{award.title}</h3>
              <p>{award.prize}</p>
            </div>
          </div>
        ))}

        <div class="penguin-card reveal-zoom" style="--delay: 0.5s">
          <div class="penguin-icon">🐧</div>
          <div class="penguin-info">
            <h3>Llavero Pingüino Linux</h3>
            <p>Premio artesanal especial — Ícono del mundo Open Source exclusivo para ganadores.</p>
          </div>
        </div>

      </div>

    </div>
  </section>
</Layout>

<style>
  .rules-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 20px 100px;
  }

  .header-content { text-align: center; margin-bottom: 60px; }
  .eyebrow { font-family: monospace; color: #ff3366; letter-spacing: 4px; font-size: 0.8rem; font-weight: 700; display: block; margin-bottom: 16px; }
  .page-title { font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 700; line-height: 1; margin-bottom: 20px; letter-spacing: -1px; }
  .gradient-text { background: linear-gradient(to right, #ff3366, var(--orange)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .page-subtitle { font-size: 1.1rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto; }

  /* ── GRID ── */
  .rules-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 40px;
    align-items: start;
  }

  /* ── TERMINAL ── */
  .rules-terminal {
    background: #08080a;
    border: 1px solid var(--border-subtle);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
  }

  .terminal-header {
    background: #111116;
    border-bottom: 1px solid var(--border-subtle);
    padding: 12px 20px;
    display: flex;
    align-items: center;
  }
  .window-controls { display: flex; gap: 8px; }
  .window-controls span { width: 12px; height: 12px; border-radius: 50%; background: #333; }
  .window-controls span:nth-child(1) { background: #ff5f56; }
  .window-controls span:nth-child(2) { background: #ffbd2e; }
  .window-controls span:nth-child(3) { background: #27c93f; }
  
  .terminal-title {
    font-family: monospace;
    color: var(--text-muted);
    font-size: 0.8rem;
    margin-left: 20px;
  }

  .terminal-content { padding: 20px; display: flex; flex-direction: column; gap: 16px; }

  .rule-item {
    display: flex;
    gap: 16px;
    padding: 16px;
    border-radius: 12px;
    background: rgba(255,255,255,0.02);
    border-left: 3px solid var(--rule-color);
    transition: background 0.3s ease;
  }
  .rule-item:hover { background: rgba(255,255,255,0.04); }
  
  .rule-alert { background: rgba(255, 51, 102, 0.05); }
  .rule-alert:hover { background: rgba(255, 51, 102, 0.08); }

  .rule-id {
    font-family: monospace;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--rule-color);
    flex-shrink: 0;
    padding-top: 4px;
  }

  .rule-title { font-size: 1rem; color: #fff; font-weight: 600; margin-bottom: 4px; }
  .rule-text { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.5; margin: 0; }

  /* ── AWARDS ── */
  .awards-container { display: flex; flex-direction: column; gap: 20px; }

  .award-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 16px;
    padding: 24px;
    display: flex;
    align-items: center;
    gap: 24px;
    overflow: hidden;
    backdrop-filter: var(--glass-blur);
    transition: transform 0.3s ease, border-color 0.3s ease;
  }
  .award-card:hover { transform: translateX(10px); border-color: var(--award-color); }

  .award-glow {
    position: absolute;
    left: 0; top: 0; bottom: 0; width: 80px;
    background: radial-gradient(circle at left, var(--award-color) 0%, transparent 70%);
    opacity: 0.15;
  }

  .award-rank {
    font-size: 3rem;
    font-weight: 700;
    color: var(--award-color);
    font-family: monospace;
    line-height: 1;
    z-index: 2;
  }

  .award-info { z-index: 2; }
  .award-info h3 { font-size: 1.2rem; color: #fff; font-weight: 600; margin-bottom: 6px; }
  .award-info p { font-size: 0.9rem; color: var(--text-secondary); margin: 0; line-height: 1.5; }

  /* Penguin */
  .penguin-card {
    background: linear-gradient(135deg, rgba(0, 255, 157, 0.05), rgba(255, 107, 0, 0.05));
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 24px;
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .penguin-icon { font-size: 2.5rem; }
  .penguin-info h3 { font-size: 1rem; color: var(--orange); margin-bottom: 4px; }
  .penguin-info p { font-size: 0.85rem; color: var(--text-muted); line-height: 1.4; margin: 0; }

  @media (max-width: 900px) {
    .rules-grid { grid-template-columns: 1fr; }
    .rules-terminal { margin-bottom: 20px; }
  }
</style>