---
import Layout from '../layouts/Layout.astro';

const rules = [
  { id: '01', text: 'No se permite la comunicación entre equipos durante la competencia.' },
  { id: '02', text: 'No se permite la copia entre equipos; si se detecta, habrá descalificación.' },
  { id: '03', text: 'No se puede copiar soluciones completas de herramientas de IA; la IA solo puede usarse para aprender o generar ideas.' },
  { id: '04', text: 'La competencia se realiza en equipos de 3 personas.' },
  { id: '05', text: 'Se puede programar en cualquier lenguaje soportado por la plataforma HackerRank.' },
  { id: '06', text: 'Los ejercicios en inglés recibirán mayor puntuación cuando aplique.' },
  { id: '07', text: 'Puntuación basada en dificultad del problema y velocidad de envío correcto; decisiones del jurado son inapelables.' }
];

const awards = [
  { rank: '1º', title: 'Primer lugar (equipo)',   prize: 'Trofeo (uno por cada integrante, 3 trofeos), Producto IEEE, Llavero "Pingüino" Linux', color: 'var(--mint)' },
  { rank: '2º', title: 'Segundo lugar (equipo)', prize: 'Producto IEEE y Pingüino Linux para los integrantes', color: '#B5B5B5' },
  { rank: '3º', title: 'Tercer lugar (equipo)',  prize: 'Pingüino Linux para integrantes', color: '#CD7F32' }
];
---

<Layout title="Reglas - DevXtreme">
  <section class="rules-section">
    <div class="grid-layout">

      <!-- RULES -->
      <div class="rules-container">
        <span class="label reveal">// REGLAMENTO</span>
        <h2 class="section-title reveal delay-1">Reglas del <span class="accent neon-title">Juego</span></h2>

        <div class="terminal-list">
          <div class="terminal-bar">
            <span class="t-dot red"></span>
            <span class="t-dot yellow"></span>
            <span class="t-dot green"></span>
            <span class="t-title">rules.sh</span>
          </div>
          <div class="terminal-body">
            {rules.map((rule, index) => (
              <div class="rule-row reveal-left" style={`--delay: ${0.12 + index * 0.06}s`}>
                <span class="rule-id">{rule.id}</span>
                <p class="rule-text">{rule.text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- AWARDS -->
      <div class="awards-container">
        <span class="label reveal">// PREMIACIÓN</span>
        <h2 class="section-title reveal delay-1">Reconoci<span class="accent neon-title">mientos</span></h2>

        <div class="podium">
          {awards.map((award, index) => (
            <div class="award-card reveal-right" style={`--rank-color: ${award.color}; --delay: ${0.14 + index * 0.08}s`}>
              <div class="rank-badge">{award.rank}</div>
              <div class="award-info">
                <strong class="award-title">{award.title}</strong>
                <p class="award-prize">{award.prize}</p>
              </div>
              <div class="award-shine"></div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  .rules-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 20px;
  }

  .grid-layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .label {
    color: var(--cyan);
    font-family: monospace;
    font-weight: 800;
    letter-spacing: 2px;
  }

  .section-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    margin: 10px 0 40px;
    color: var(--text-primary);
    transition: color 0.4s ease;
  }

  .accent {
    background: linear-gradient(90deg, var(--cyan), var(--magenta));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* ── TERMINAL BOX ── */
  .terminal-list {
    background: var(--bg-terminal);
    border: 1px solid var(--border-default);
    border-radius: 8px;
    overflow: hidden;
    transition: background 0.4s ease, border-color 0.4s ease;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 15px;
    background: var(--bg-code);
    border-bottom: 1px solid var(--border-default);
  }

  .t-dot {
    width: 12px; height: 12px;
    border-radius: 50%;
    display: inline-block;
  }
  .t-dot.red    { background: #ff5f57; }
  .t-dot.yellow { background: #febc2e; }
  .t-dot.green  { background: #28c840; }

  .t-title {
    font-family: monospace;
    font-size: 0.75rem;
    color: var(--text-faint);
    margin-left: 8px;
  }

  .terminal-body { padding: 8px; }

  .rule-row {
    display: flex;
    gap: 20px;
    padding: 18px 12px;
    border-bottom: 1px solid var(--border-rule);
    border-radius: 4px;
    transition: background 0.2s ease;
  }
  .rule-row:last-child { border-bottom: none; }
  .rule-row:hover { background: rgba(0, 212, 255, 0.04); }
  [data-theme="dark"] .rule-row:hover { background: rgba(0, 212, 255, 0.07); }

  .rule-id {
    font-family: monospace;
    font-weight: 800;
    color: var(--magenta);
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .rule-text {
    color: var(--text-secondary);
    line-height: 1.6;
    font-size: 0.95rem;
    transition: color 0.4s ease;
    margin: 0;
  }

  /* ── AWARDS ── */
  .podium {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .award-card {
    display: flex;
    align-items: center;
    background: var(--bg-card);
    padding: 20px;
    border-left: 5px solid var(--rank-color);
    box-shadow: var(--shadow-card);
    transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.4s ease;
    position: relative;
    overflow: hidden;
  }

  .award-card:hover {
    transform: translateX(6px);
    box-shadow: var(--shadow-card-hover);
  }

  .award-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 60%, rgba(255,255,255,0.04) 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .award-card:hover .award-shine { opacity: 1; }

  .rank-badge {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--rank-color);
    margin-right: 25px;
    min-width: 50px;
    text-align: center;
    text-shadow: 0 0 10px var(--rank-color);
    transition: text-shadow 0.3s ease;
  }

  .award-card:hover .rank-badge {
    text-shadow: 0 0 20px var(--rank-color), 0 0 40px var(--rank-color);
  }

  .award-title {
    display: block;
    font-size: 1.1rem;
    color: var(--text-card-title);
    margin-bottom: 4px;
    transition: color 0.4s ease;
  }

  .award-prize {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0;
    transition: color 0.4s ease;
  }

  @media (max-width: 900px) {
    .grid-layout { grid-template-columns: 1fr; gap: 60px; }
    .section-title { font-size: 2.2rem; }
  }
</style>