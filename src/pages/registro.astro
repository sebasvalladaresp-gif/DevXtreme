---
import Layout from '../layouts/Layout.astro';

const socials = [
  {
    name: "Adrián Urresta",
    handle: "@adrx_sanz",
    role: "Presidente IEEE CS Student Branch UTN",
    url: "https://www.instagram.com/adrx_sanz",
    color: "var(--orange)",
  },
  {
    name: "Dario López",
    handle: "@darlopez05",
    role: "Presidente Club Programación UTN",
    url: "https://www.instagram.com/darlopez05/",
    color: "var(--orange-light)",
  },
  {
    name: "IEEE Computer Society UTN",
    handle: "@ieee_utncs",
    role: "Capítulo Estudiantil IEEE UTN",
    url: "https://www.instagram.com/ieee_utncs?igsh=Y2VueDJpNW96ZTZw",
    color: "var(--green)",
  },
  {
    name: "Club de Programación UTN",
    handle: "@clubprogramacionutn",
    role: "Comunidad de Programación UTN",
    url: "https://www.instagram.com/clubprogramacionutn?igsh=ZnJ0OGl1NW9uamxi",
    color: "var(--green)",
  },
];
---

<Layout title="Registro - DevXtreme 3.0">
  <section class="register-section">
    <div class="header-content reveal">
      <span class="eyebrow">// JOIN THE MISSION</span>
      <h1 class="page-title">Asegura tu <span class="gradient-text">Acceso</span></h1>
      <p class="page-subtitle">Las plazas son limitadas. Registra a tu equipo de 3 integrantes para competir en DevXtreme 3.0.</p>
    </div>

    <!-- MAIN CTA BOX -->
    <div class="cta-container reveal-zoom" style="--delay: 0.2s">
      <div class="cta-glow"></div>
      <div class="cta-content">
        <div class="cta-icon">🚀</div>
        <h2>Formulario de Inscripción</h2>
        <p>Llena los datos de tu equipo en nuestro formulario oficial. Asegúrate de tener los nombres completos, correos institucionales y el nombre de tu escuadrón.</p>
        <a href="https://forms.gle/A18q5fC2j4v5sHj96" target="_blank" class="btn-register">
          <span>ABRIR FORMULARIO</span>
        </a>
      </div>
    </div>

    <!-- CONTACT SECTION -->
    <div class="contact-section reveal" style="--delay: 0.4s">
      <h2 class="section-heading">Soporte & Contacto</h2>
      <p class="section-desc">¿Problemas con el registro? Contáctanos a través de nuestros canales oficiales.</p>
      
      <div class="whatsapp-box">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
        <span>Soporte Directo:</span>
        <a href="https://wa.me/593978640544" target="_blank">0978640544</a>
      </div>

      <div class="social-grid">
        {socials.map((social) => (
          <a href={social.url} target="_blank" class="social-card" style={`--social-color: ${social.color}`}>
            <div class="social-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </div>
            <div class="social-info">
              <h3>{social.name}</h3>
              <span class="social-handle">{social.handle}</span>
              <p>{social.role}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .register-section {
    max-width: 900px;
    margin: 0 auto;
    padding: 80px 20px 100px;
  }

  .header-content { text-align: center; margin-bottom: 60px; }
  .eyebrow { font-family: monospace; color: var(--green); letter-spacing: 4px; font-size: 0.8rem; font-weight: 700; display: block; margin-bottom: 16px; }
  .page-title { font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 700; line-height: 1; margin-bottom: 20px; letter-spacing: -1px; }
  .gradient-text { background: linear-gradient(to right, var(--green), var(--orange)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .page-subtitle { font-size: 1.1rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto; line-height: 1.6; }

  /* ── CTA BOX ── */
  .cta-container {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border-accent);
    border-radius: 32px;
    padding: 60px 40px;
    text-align: center;
    overflow: hidden;
    margin-bottom: 80px;
    backdrop-filter: var(--glass-blur);
  }

  .cta-glow {
    position: absolute;
    inset: -50%;
    background: conic-gradient(from 0deg, transparent 0 340deg, var(--green) 360deg);
    animation: rotateGlow 8s linear infinite;
    opacity: 0.15;
    z-index: 0;
  }

  @keyframes rotateGlow {
    100% { transform: rotate(360deg); }
  }

  .cta-content {
    position: relative;
    z-index: 2;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-icon { font-size: 4rem; margin-bottom: 24px; }
  .cta-content h2 { font-size: 2.2rem; font-weight: 700; color: #fff; margin-bottom: 16px; letter-spacing: -0.5px;}
  .cta-content p { font-size: 1.05rem; color: var(--text-secondary); line-height: 1.6; margin-bottom: 40px; }

  .btn-register {
    display: inline-block;
    background: #fff;
    color: #000;
    text-decoration: none;
    font-weight: 700;
    font-size: 1.1rem;
    padding: 20px 48px;
    border-radius: 40px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 10px 30px rgba(0, 255, 157, 0.2);
  }
  .btn-register:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 15px 40px rgba(0, 255, 157, 0.4), 0 0 20px rgba(255,255,255,0.5);
  }

  /* ── CONTACT SECTION ── */
  .contact-section {
    border-top: 1px solid var(--border-subtle);
    padding-top: 60px;
    text-align: center;
  }

  .section-heading { font-size: 1.8rem; color: #fff; margin-bottom: 12px; }
  .section-desc { color: var(--text-muted); margin-bottom: 40px; }

  .whatsapp-box {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: rgba(37, 211, 102, 0.1);
    border: 1px solid rgba(37, 211, 102, 0.3);
    padding: 16px 32px;
    border-radius: 20px;
    margin-bottom: 40px;
    color: #25D366;
    font-weight: 600;
    font-size: 1.1rem;
  }
  .whatsapp-box a { color: #25D366; text-decoration: none; border-bottom: 1px dashed; transition: opacity 0.3s; }
  .whatsapp-box a:hover { opacity: 0.8; }

  .social-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    text-align: left;
  }

  .social-card {
    display: flex;
    align-items: center;
    gap: 20px;
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border-subtle);
    padding: 24px;
    border-radius: 16px;
    text-decoration: none;
    transition: transform 0.3s ease, border-color 0.3s ease, background 0.3s ease;
  }
  .social-card:hover {
    transform: translateY(-5px);
    border-color: var(--social-color);
    background: rgba(255,255,255,0.04);
  }

  .social-icon {
    width: 48px; height: 48px;
    border-radius: 12px;
    background: rgba(255,255,255,0.05);
    display: flex; align-items: center; justify-content: center;
    color: var(--social-color);
    flex-shrink: 0;
  }
  .social-icon svg { width: 24px; height: 24px; }

  .social-info h3 { font-size: 1rem; color: #fff; margin-bottom: 4px; }
  .social-handle { font-family: monospace; font-size: 0.8rem; color: var(--social-color); display: block; margin-bottom: 6px; }
  .social-info p { font-size: 0.85rem; color: var(--text-muted); margin: 0; line-height: 1.4; }

  @media (max-width: 768px) {
    .cta-container { padding: 40px 20px; }
    .btn-register { padding: 16px 32px; font-size: 1rem; }
    .social-grid { grid-template-columns: 1fr; }
  }
</style>