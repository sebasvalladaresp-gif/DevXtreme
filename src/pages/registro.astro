---
// src/pages/registro.astro
import Layout from '../layouts/Layout.astro';



const socials = [
  {
    name: "Adrián Urresta",
    handle: "@adrx_sanz",
    role: "Presidente IEEE CS Student Branch UTN",
    url: "https://www.instagram.com/adrx_sanz?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==",
    color: "var(--cyan)",
  },
  {
    name: "Dario López",
    handle: "@darlopez05",
    role: "Presidente Club Programación UTN",
    url: "https://www.instagram.com/darlopez05/",
    color: "var(--sky-blue)",
  },
  {
    name: "IEEE Computer Society UTN",
    handle: "@ieee_utncs",
    role: "Capítulo Estudiantil IEEE UTN",
    url: "https://www.instagram.com/ieee_utncs/",
    color: "var(--purple)",
  },
  {
    name: "Club de Programación UTN",
    handle: "@clubprogramacionutn",
    role: "Comunidad de Programación UTN",
    url: "https://www.instagram.com/clubprogramacionutn/",
    color: "var(--mint)",
  },
];
---

<Layout title="Registro - DevXtreme">
  <section class="registro-section">

    <!-- ══════════════════════════════
         HEADER
    ═══════════════════════════════ -->
    <div class="page-header">
      <span class="prefix reveal">// INSCRIPCIONES</span>
      <h1 class="main-title reveal delay-1">
        Registro <span class="accent neon-title">Gratuito</span>
      </h1>
      <p class="subtitle reveal delay-2">
        La competencia es completamente gratuita y abierta a todos. Únicamente completa tu registro a continuación.
      </p>
    </div>



    <!-- ══════════════════════════════
         FORM CTA BUTTON
    ═══════════════════════════════ -->
    <div class="form-cta-section">
      <div class="form-cta-container">
        <h3 class="form-cta-title reveal">Completa tu Registro</h3>
        <p class="form-cta-description reveal delay-1">
          Haz clic en el botón de abajo para completar el formulario oficial de inscripción y confirmar tu participación en DevXtreme 3.0.
        </p>
        <a
          href="https://docs.google.com/forms/d/e/1FAIpQLSf4WLvdGXD1bmyWqee9N5IfMA6szlF5eUniLZvVFHSRzQWXCw/viewform?usp=header"
          target="_blank"
          rel="noopener noreferrer"
          class="form-cta-button reveal delay-2"
        >
          <span>IR AL FORMULARIO</span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
               stroke-linejoin="round" class="cta-arrow">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- ══════════════════════════════
         SOCIAL LINKS
    ═══════════════════════════════ -->
    <div class="social-section">
      <span class="prefix reveal">// SÍGUENOS</span>
      <h2 class="section-title reveal delay-1">Comunidad &amp; <span class="accent neon-title">Contacto</span></h2>
      <p class="social-intro reveal delay-2">
        Mantente al día con las novedades del evento siguiendo a los organizadores y comunidades en Instagram.
      </p>

      <div class="social-grid">
        {socials.map((s, i) => (
          <a
            href={s.url}
            target="_blank"
            rel="noopener noreferrer"
            class="social-card reveal-zoom"
            style={`--s-color: ${s.color}; --delay: ${0.1 + i * 0.1}s`}
            aria-label={`Instagram de ${s.name}`}
          >
            <!-- Instagram SVG icon -->
            <div class="ig-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="1.8"
                   stroke-linecap="round" stroke-linejoin="round" class="ig-icon">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
            </div>
            <div class="social-info">
              <span class="social-name">{s.name}</span>
              <span class="social-handle">{s.handle}</span>
              <span class="social-role">{s.role}</span>
            </div>
            <div class="social-arrow">→</div>
            <div class="social-bar"></div>
          </a>
        ))}
      </div>
    </div>

  </section>
</Layout>

<style>
  /* ══════════════════════════════════
     LAYOUT
  ══════════════════════════════════ */
  .registro-section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 80px 20px 60px;
  }

  /* ══════════════════════════════════
     PAGE HEADER
  ══════════════════════════════════ */
  .page-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .prefix {
    display: inline-block;
    color: var(--cyan);
    font-family: monospace;
    font-weight: 800;
    letter-spacing: 3px;
    font-size: 0.85rem;
    margin-bottom: 12px;
  }

  .main-title {
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1.15;
    margin: 10px 0 20px;
    transition: color 0.4s ease;
  }

  .accent {
    background: linear-gradient(90deg, var(--sky-blue), var(--cyan), var(--purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .subtitle {
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
    font-size: clamp(0.85rem, 2vw, 1rem);
    transition: color 0.4s ease;
  }

  /* ══════════════════════════════════
     PRICING GRID
  ══════════════════════════════════ */

  /* ══════════════════════════════════
     BUTTONS (removed - payment methods deleted)
  ══════════════════════════════════ */

  /* ══════════════════════════════════
     SOCIAL SECTION
  ══════════════════════════════════ */
  .social-section { }

  .social-intro {
    color: var(--text-muted);
    max-width: 560px;
    line-height: 1.7;
    font-size: clamp(0.85rem, 2vw, 0.95rem);
    margin-bottom: 40px;
    transition: color 0.4s ease;
  }

  .social-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .social-card {
    display: flex;
    align-items: center;
    gap: 16px;
    background: var(--bg-card);
    border: 1px solid var(--border-default);
    padding: 20px 22px;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275),
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      background 0.4s ease;
  }

  .social-card:hover {
    transform: translateY(-5px) scale(1.01);
    border-color: var(--s-color);
    box-shadow: 0 16px 36px rgba(0,0,0,0.1);
  }

  [data-theme="dark"] .social-card:hover {
    box-shadow: 0 16px 40px rgba(0,0,0,0.5), 0 0 16px rgba(255,122,0,0.08);
  }

  /* IG icon wrapper */
  .ig-icon-wrap {
    flex-shrink: 0;
    width: 48px; height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(255,122,0,0.12), rgba(255,0,76,0.08));
    border: 1px solid rgba(255,122,0,0.2);
    color: var(--s-color);
    transition: transform 0.3s ease, background 0.3s ease;
  }
  .social-card:hover .ig-icon-wrap {
    transform: scale(1.1) rotate(-5deg);
    background: linear-gradient(135deg, rgba(255,122,0,0.2), rgba(255,0,76,0.14));
  }
  [data-theme="dark"] .ig-icon-wrap {
    background: linear-gradient(135deg, rgba(255,122,0,0.16), rgba(255,0,76,0.1));
  }

  .ig-icon { width: 22px; height: 22px; }

  /* Social text */
  .social-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .social-name {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text-card-title);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.4s ease;
  }

  .social-handle {
    font-size: 0.78rem;
    font-weight: 800;
    color: var(--s-color);
    font-family: monospace;
    letter-spacing: 0.5px;
  }

  .social-role {
    font-size: 0.7rem;
    color: var(--text-faint);
    font-family: system-ui, sans-serif;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.4s ease;
  }

  /* Arrow */
  .social-arrow {
    margin-left: auto;
    font-size: 1.1rem;
    color: var(--text-faint);
    flex-shrink: 0;
    transition: transform 0.3s ease, color 0.3s ease;
  }
  .social-card:hover .social-arrow {
    transform: translateX(4px);
    color: var(--s-color);
  }

  /* Bottom color bar */
  .social-bar {
    position: absolute;
    bottom: 0; left: 0;
    width: 100%; height: 3px;
    background: linear-gradient(90deg, var(--s-color), transparent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }
  .social-card:hover .social-bar { transform: scaleX(1); }

  /* ══════════════════════════════════
     FORM CTA SECTION
  ══════════════════════════════════ */
  .form-cta-section {
    max-width: 780px;
    margin: 0 auto 80px;
    padding: 0 20px;
  }

  .form-cta-container {
    background: var(--bg-card);
    border: 2px solid var(--border-accent);
    border-radius: 12px;
    padding: clamp(28px, 6vw, 48px) clamp(24px, 5vw, 40px);
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: all 0.4s ease;
  }

  .form-cta-container::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,122,0,0.06), rgba(255,0,76,0.04));
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .form-cta-container:hover {
    border-color: var(--cyan);
    box-shadow: 0 16px 48px rgba(0,212,255,0.15);
  }

  [data-theme="dark"] .form-cta-container:hover {
    box-shadow: 0 16px 60px rgba(255,122,0,0.25), 0 0 30px rgba(255,0,76,0.1);
  }

  .form-cta-container:hover::before { opacity: 1; }

  .form-cta-title {
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 800;
    background: linear-gradient(90deg, var(--cyan), var(--magenta));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 12px;
    letter-spacing: 0.5px;
    position: relative;
    z-index: 2;
  }

  .form-cta-description {
    color: var(--text-muted);
    font-size: clamp(0.85rem, 2.5vw, 0.95rem);
    line-height: 1.7;
    max-width: 500px;
    margin: 0 auto 24px;
    position: relative;
    z-index: 2;
    transition: color 0.4s ease;
  }

  .form-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: clamp(14px, 3vw, 18px) clamp(28px, 6vw, 42px);
    font-family: 'Orbitron', sans-serif;
    font-size: clamp(0.75rem, 2vw, 0.9rem);
    font-weight: 800;
    letter-spacing: 1.5px;
    text-decoration: none;
    text-transform: uppercase;
    
    background: linear-gradient(135deg, rgba(255,0,110,0.12), rgba(0,212,255,0.1));
    border: 2px solid var(--magenta);
    color: var(--magenta);
    
    position: relative;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.2, 0.7, 0.2, 1);
    cursor: pointer;
  }

  .form-cta-button::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transform: translateX(-100%);
    transition: transform 0.5s ease;
    z-index: 1;
  }

  .form-cta-button:hover::before { transform: translateX(100%); }

  .form-cta-button span {
    position: relative;
    z-index: 2;
    background: linear-gradient(90deg, var(--magenta), var(--cyan));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    transition: filter 0.3s ease;
  }

  .form-cta-button:hover span {
    filter: drop-shadow(0 0 8px rgba(255,0,110,0.5));
  }

  .cta-arrow {
    width: 20px;
    height: 20px;
    position: relative;
    z-index: 2;
    transition: transform 0.3s ease;
  }

  .form-cta-button:hover {
    transform: translateY(-4px) scale(1.02);
    border-color: var(--cyan);
    box-shadow: 0 12px 32px rgba(255,0,110,0.25);
  }

  [data-theme="dark"] .form-cta-button:hover {
    box-shadow: 0 12px 40px rgba(255,0,110,0.4), 0 0 20px rgba(0,212,255,0.15);
  }

  .form-cta-button:hover .cta-arrow {
    transform: translateX(3px);
  }

  /* ══════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════ */
  @media (max-width: 768px) {
    .registro-section { padding: 100px 16px 50px; }

    .social-grid {
      grid-template-columns: 1fr;
    }

    .form-cta-section {
      margin: 0 16px 80px;
      padding: 0;
    }

    .form-cta-container {
      padding: 32px 20px;
    }

    .form-cta-title { font-size: 1.6rem; }
    .form-cta-button { padding: 14px 24px; }

    .main-title  { font-size: 1.9rem; }
    .section-title { font-size: 1.7rem; }
  }

  @media (max-width: 480px) {
    .social-name, .social-role { white-space: normal; }

    .form-cta-section { margin: 0 12px 60px; }
    .form-cta-container { padding: 24px 16px; }
    .form-cta-title { font-size: 1.3rem; }
    .form-cta-description { font-size: 0.8rem; margin-bottom: 18px; }
    .form-cta-button { padding: 12px 20px; gap: 8px; }
    .cta-arrow { width: 18px; height: 18px; }
  }
</style>