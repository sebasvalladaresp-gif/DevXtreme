---
// src/layouts/Layout.astro
interface Props {
    title: string;
}

const { title } = Astro.props;
const { pathname } = Astro.url;
const mostrarFlecha = pathname !== "/" && pathname !== "/index.html";
---

<!doctype html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;800&display=swap" rel="stylesheet" />
</head>

<body>
    <div class="tech-grid-bg">

        <header class="topbar">
            <div class="logo">
                <a href="/" aria-label="Inicio"><span class="logo-gradient">DEVXTREME</span></a>
            </div>
            <p class="tag">COMPETENCIA DE PROGRAMACIÓN</p>
            <nav class="nav-container">

                <!-- THEME SWITCH -->
                <label class="theme-switch" title="Cambiar tema">
                    <input type="checkbox" class="theme-switch__checkbox" id="theme-toggle">
                    <div class="theme-switch__container">
                        <div class="theme-switch__clouds"></div>
                        <div class="theme-switch__stars-container">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 144 55" fill="none">
                                <path fill-rule="evenodd" clip-rule="evenodd" d="M135.831 3.00688C135.055 3.85027 134.111 4.29946 133 4.35447C134.111 4.40947 135.055 4.85867 135.831 5.71123C136.607 6.55462 136.996 7.56303 136.996 8.72727C136.996 7.95722 137.172 7.25134 137.525 6.59129C137.886 5.93124 138.372 5.39954 138.98 5.00535C139.598 4.60199 140.268 4.39114 141 4.35447C139.88 4.2903 138.936 3.85027 138.16 3.00688C137.384 2.16348 136.996 1.16425 136.996 0C136.996 1.16425 136.607 2.16348 135.831 3.00688ZM31 23.3545C32.1114 23.2995 33.0551 22.8503 33.8313 22.0069C34.6075 21.1635 34.9956 20.1642 34.9956 19C34.9956 20.1642 35.3837 21.1635 36.1599 22.0069C36.9361 22.8503 37.8798 23.2903 39 23.3545C38.2679 23.3911 37.5976 23.602 36.9802 24.0053C36.3716 24.3995 35.8864 24.9312 35.5248 25.5913C35.172 26.2513 34.9956 26.9572 34.9956 27.7273C34.9956 26.563 34.6075 25.5546 33.8313 24.7112C33.0551 23.8587 32.1114 23.4095 31 23.3545ZM0 36.3545C1.11136 36.2995 2.05513 35.8503 2.83131 35.0069C3.6075 34.1635 3.99559 33.1642 3.99559 32C3.99559 33.1642 4.38368 34.1635 5.15987 35.0069C5.93605 35.8503 6.87982 36.2903 8 36.3545C7.26792 36.3911 6.59757 36.602 5.98015 37.0053C5.37155 37.3995 4.88644 37.9312 4.52481 38.5913C4.172 39.2513 3.99559 39.9572 3.99559 40.7273C3.99559 39.563 3.6075 38.5546 2.83131 37.7112C2.05513 36.8587 1.11136 36.4095 0 36.3545ZM56.8313 24.0069C56.0551 24.8503 55.1114 25.2995 54 25.3545C55.1114 25.4095 56.0551 25.8587 56.8313 26.7112C57.6075 27.5546 57.9956 28.563 57.9956 29.7273C57.9956 28.9572 58.172 28.2513 58.5248 27.5913C58.8864 26.9312 59.3716 26.3995 59.9802 26.0053C60.5976 25.602 61.2679 25.3911 62 25.3545C60.8798 25.2903 59.9361 24.8503 59.1599 24.0069C58.3837 23.1635 57.9956 22.1642 57.9956 21C57.9956 22.1642 57.6075 23.1635 56.8313 24.0069ZM81 25.3545C82.1114 25.2995 83.0551 24.8503 83.8313 24.0069C84.6075 23.1635 84.9956 22.1642 84.9956 21C84.9956 22.1642 85.3837 23.1635 86.1599 24.0069C86.9361 24.8503 87.8798 25.2903 89 25.3545C88.2679 25.3911 87.5976 25.602 86.9802 26.0053C86.3716 26.3995 85.8864 26.9312 85.5248 27.5913C85.172 28.2513 84.9956 28.9572 84.9956 29.7273C84.9956 28.563 84.6075 27.5546 83.8313 26.7112C83.0551 25.8587 82.1114 25.4095 81 25.3545ZM136 36.3545C137.111 36.2995 138.055 35.8503 138.831 35.0069C139.607 34.1635 139.996 33.1642 139.996 32C139.996 33.1642 140.384 34.1635 141.16 35.0069C141.936 35.8503 142.88 36.2903 144 36.3545C143.268 36.3911 142.598 36.602 141.98 37.0053C141.372 37.3995 140.886 37.9312 140.525 38.5913C140.172 39.2513 139.996 39.9572 139.996 40.7273C139.996 39.563 139.607 38.5546 138.831 37.7112C138.055 36.8587 137.111 36.4095 136 36.3545ZM101.831 49.0069C101.055 49.8503 100.111 50.2995 99 50.3545C100.111 50.4095 101.055 50.8587 101.831 51.7112C102.607 52.5546 102.996 53.563 102.996 54.7273C102.996 53.9572 103.172 53.2513 103.525 52.5913C103.886 51.9312 104.372 51.3995 104.98 51.0053C105.598 50.602 106.268 50.3911 107 50.3545C105.88 50.2903 104.936 49.8503 104.16 49.0069C103.384 48.1635 102.996 47.1642 102.996 46C102.996 47.1642 102.607 48.1635 101.831 49.0069Z" fill="currentColor"></path>
                            </svg>
                        </div>
                        <div class="theme-switch__circle-container">
                            <div class="theme-switch__sun-moon-container">
                                <div class="theme-switch__moon">
                                    <div class="theme-switch__spot"></div>
                                    <div class="theme-switch__spot"></div>
                                    <div class="theme-switch__spot"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </label>

                <button id="menu-btn" class="menu-hamburger">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>

                <div id="nav-menu" class="nav-menu">
                    <a href="/agradecimiento">AGRADECIMIENTO</a>
                    <a href="/categorias">CATEGORÍAS</a>
                    <a href="/cronograma">CRONOGRAMA</a>
                    <a href="/Explorar">EXPLORAR EVENTO</a>
                    <a href="/">INICIO</a>
                    <a href="/registro" target="_blank" class="register-link">REGISTRARSE</a>
                    <a href="/reglas">REGLAS</a>
                </div>
            </nav>
        </header>

        <main class="content-wrapper">
            <slot />
        </main>

        <div class="bottom-logos">
            <div class="bottom-logo-left">
                <img src="/Ieee.svg" alt="IEEE Logo" class="bottom-logo ieee-logo" />
            </div>
            <div class="bottom-logo-right">
                <img src="/Utn.svg" alt="UTN Logo" class="bottom-logo cp-logo" />
            </div>
        </div>

    </div>

    <script is:inline>
    // ── THEME LOGIC ──────────────────────────────────────────────
    const applyTheme = (dark) => {
        document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
        localStorage.setItem('devxtreme-theme', dark ? 'dark' : 'light');
    };

    const initTheme = () => {
        const toggle = document.getElementById('theme-toggle');
        if (!toggle) return;
        const saved = localStorage.getItem('devxtreme-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = saved ? saved === 'dark' : prefersDark;
        toggle.checked = isDark;
        applyTheme(isDark);
        toggle.addEventListener('change', () => applyTheme(toggle.checked));
    };

    // ── MENU LOGIC ────────────────────────────────────────────────
    const initMenu = () => {
        const menuBtn = document.getElementById('menu-btn');
        const navMenu = document.getElementById('nav-menu');
        const getHomeBtn = () => document.querySelector('.home-btn');

        if (menuBtn && navMenu) {
            const toggleHomeBtn = (isHidden) => {
                const homeBtn = getHomeBtn();
                if (homeBtn) {
                    homeBtn.style.opacity = isHidden ? '0' : '1';
                    homeBtn.style.visibility = isHidden ? 'hidden' : 'visible';
                    homeBtn.style.transition = 'opacity 0.3s ease';
                }
            };

            menuBtn.replaceWith(menuBtn.cloneNode(true));
            const newMenuBtn = document.getElementById('menu-btn');

            newMenuBtn.addEventListener('click', () => {
                const isOpen = newMenuBtn.classList.toggle('open');
                navMenu.classList.toggle('active');
                toggleHomeBtn(isOpen);
            });

            document.addEventListener('click', (e) => {
                if (!newMenuBtn.contains(e.target) && !navMenu.contains(e.target)) {
                    newMenuBtn.classList.remove('open');
                    navMenu.classList.remove('active');
                    toggleHomeBtn(false);
                }
            });
        }
    };

    const init = () => { initTheme(); initMenu(); };

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
    document.addEventListener('astro:after-swap', init);
    </script>

    {mostrarFlecha && (
        <a class="home-btn" href="/" aria-label="Ir al inicio">←</a>
    )}
</body>
</html>

<style is:global>
    /* =============================================
       CSS VARIABLES — LIGHT & DARK
    ============================================== */
    :root,
    [data-theme="light"] {
        --yellow: #ffcc00;
        --orange: #ff7a00;
        --red: #ff004c;

        --bg: #fdfdfd;
        --bg-secondary: #ffffff;
        --bg-card: #ffffff;
        --bg-card-hover: #fff8f0;
        --bg-nav: rgba(255, 255, 255, 0.97);
        --bg-header: rgba(255, 255, 255, 0.92);
        --bg-code: #f8f8f8;
        --bg-email: #f9f9f9;
        --bg-terminal: rgba(255, 255, 255, 0.5);

        --text-primary: #111111;
        --text-secondary: #444444;
        --text-muted: #666666;
        --text-faint: #999999;
        --text-card-title: #111;
        --text-time: #444;

        --border-default: rgba(0, 0, 0, 0.08);
        --border-accent: rgba(255, 122, 0, 0.3);
        --border-rule: rgba(0, 0, 0, 0.05);
        --border-nav: rgba(255, 122, 0, 0.2);

        --grid: rgba(255, 120, 0, 0.05);
        --logo-glow: rgba(255, 122, 0, 0.4);
        --shadow-card: 0 10px 30px rgba(0, 0, 0, 0.06);
        --shadow-card-hover: 0 20px 40px rgba(0, 0, 0, 0.1);
        --scan-line: rgba(0, 0, 0, 0.08);

        --topbar-border: rgba(255, 120, 0, 0.1);
        --home-btn-shadow: 0 10px 20px rgba(255, 122, 0, 0.3);

        --footer-text: #666;
        --footer-border: rgba(255, 122, 0, 0.1);
        --wa-bg: #d9fdd3;
        --wa-color: #128c7e;
        --action-bg: #f0f2f5;
        --action-color: #555;
        --profile-border: rgba(255, 122, 0, 0.2);
        --contact-divider: #f0f0f0;
        --email-text: #444;

        --stat-bar-shadow: rgba(255, 122, 0, 0.05);
        --card-box-shadow: 4px 4px 0px rgba(0, 0, 0, 0.05);
    }

    [data-theme="dark"] {
        --bg: #0d0d0f;
        --bg-secondary: #121214;
        --bg-card: #18181c;
        --bg-card-hover: #1e1e24;
        --bg-nav: rgba(13, 13, 15, 0.98);
        --bg-header: rgba(10, 10, 12, 0.95);
        --bg-code: #0f0f13;
        --bg-email: #1a1a1f;
        --bg-terminal: rgba(18, 18, 22, 0.8);

        --text-primary: #f0f0f0;
        --text-secondary: #c8c8d0;
        --text-muted: #9090a0;
        --text-faint: #606070;
        --text-card-title: #f0f0f0;
        --text-time: #b0b0c0;

        --border-default: rgba(255, 255, 255, 0.07);
        --border-accent: rgba(255, 122, 0, 0.35);
        --border-rule: rgba(255, 255, 255, 0.05);
        --border-nav: rgba(255, 122, 0, 0.25);

        --grid: rgba(255, 120, 0, 0.04);
        --logo-glow: rgba(255, 122, 0, 0.55);
        --shadow-card: 0 10px 30px rgba(0, 0, 0, 0.5);
        --shadow-card-hover: 0 20px 50px rgba(0, 0, 0, 0.7);
        --scan-line: rgba(255, 255, 255, 0.03);

        --topbar-border: rgba(255, 120, 0, 0.15);
        --home-btn-shadow: 0 10px 20px rgba(255, 122, 0, 0.5);

        --footer-text: #888;
        --footer-border: rgba(255, 122, 0, 0.15);
        --wa-bg: #0d2e21;
        --wa-color: #25D366;
        --action-bg: #252530;
        --action-color: #aaa;
        --profile-border: rgba(255, 122, 0, 0.3);
        --contact-divider: #252530;
        --email-text: #c0c0cc;

        --stat-bar-shadow: rgba(255, 122, 0, 0.12);
        --card-box-shadow: 4px 4px 0px rgba(0, 0, 0, 0.5);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html {
        transition: background-color 0.4s ease, color 0.4s ease;
    }

    body {
        font-family: "Orbitron", sans-serif;
        background: var(--bg);
        color: var(--text-primary);
        overflow-x: hidden;
        transition: background-color 0.4s ease, color 0.4s ease;
    }

    /* =============================================
       FONDO ANIMADO
    ============================================== */
    .tech-grid-bg {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
        background-color: var(--bg);
        background-image:
            linear-gradient(var(--grid) 1px, transparent 1px),
            linear-gradient(90deg, var(--grid) 1px, transparent 1px);
        background-size: 50px 50px;
        transition: background-color 0.4s ease;
    }

    .tech-grid-bg::before {
        content: "";
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        z-index: 0;
        background:
            radial-gradient(circle at 15% 20%, rgba(255, 204, 0, 0.08), transparent 88%),
            radial-gradient(circle at 85% 30%, rgba(255, 0, 76, 0.08), transparent 80%),
            radial-gradient(circle at 50% 80%, rgba(255, 122, 0, 0.08), transparent 80%);
        filter: blur(60px);
        animation: glowMove 15s ease-in-out infinite alternate;
    }

    [data-theme="dark"] .tech-grid-bg::before {
        background:
            radial-gradient(circle at 15% 20%, rgba(255, 204, 0, 0.12), transparent 88%),
            radial-gradient(circle at 85% 30%, rgba(255, 0, 76, 0.12), transparent 80%),
            radial-gradient(circle at 50% 80%, rgba(255, 122, 0, 0.12), transparent 80%);
    }

    @keyframes glowMove {
        from { transform: scale(1); }
        to { transform: scale(1.1) translate(2%, 2%); }
    }

    .tech-grid-bg::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.04) 0%, rgba(0, 0, 0, 0.02) 50%, rgba(255, 255, 255, 0.04) 100%),
            repeating-linear-gradient(180deg, var(--scan-line) 0px, var(--scan-line) 1px, transparent 1px, transparent 4px);
        mix-blend-mode: overlay;
        opacity: 0.4;
        animation: scanMove 8s linear infinite;
    }

    @keyframes scanMove {
        from { transform: translateY(0); }
        to { transform: translateY(60px); }
    }

    /* =============================================
       GLOBAL ANIMATIONS
    ============================================== */
    .reveal {
        opacity: 0;
        transform: translateY(20px);
        animation: revealUp 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
        animation-delay: var(--delay, 0s);
    }
    .reveal-left {
        opacity: 0;
        transform: translateX(-24px);
        animation: revealLeft 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
        animation-delay: var(--delay, 0s);
    }
    .reveal-right {
        opacity: 0;
        transform: translateX(24px);
        animation: revealRight 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
        animation-delay: var(--delay, 0s);
    }
    .reveal-zoom {
        opacity: 0;
        transform: translateY(16px) scale(0.98);
        animation: revealZoom 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
        animation-delay: var(--delay, 0s);
    }

    .delay-1 { --delay: 0.12s; }
    .delay-2 { --delay: 0.24s; }
    .delay-3 { --delay: 0.36s; }
    .delay-4 { --delay: 0.48s; }
    .delay-5 { --delay: 0.6s; }

    .neon-title {
        text-shadow: 0 0 12px rgba(255, 122, 0, 0.3), 0 0 24px rgba(255, 0, 76, 0.2);
        animation: neonPulse 3s ease-in-out infinite;
    }
    [data-theme="dark"] .neon-title {
        text-shadow: 0 0 16px rgba(255, 122, 0, 0.6), 0 0 32px rgba(255, 0, 76, 0.4), 0 0 60px rgba(255, 122, 0, 0.2);
    }

    .pulse-glow { animation: glowPulse 2.5s ease-in-out infinite; }

    @keyframes revealUp    { to { opacity: 1; transform: translateY(0); } }
    @keyframes revealLeft  { to { opacity: 1; transform: translateX(0); } }
    @keyframes revealRight { to { opacity: 1; transform: translateX(0); } }
    @keyframes revealZoom  { to { opacity: 1; transform: translateY(0) scale(1); } }

    @keyframes neonPulse {
        0%, 100% { text-shadow: 0 0 10px rgba(255, 122, 0, 0.2), 0 0 24px rgba(255, 0, 76, 0.12); }
        50%       { text-shadow: 0 0 18px rgba(255, 122, 0, 0.4), 0 0 32px rgba(255, 0, 76, 0.2); }
    }
    @keyframes glowPulse {
        0%, 100% { opacity: 0.12; transform: scale(0.95); }
        50%       { opacity: 0.35; transform: scale(1.05); }
    }

    /* =============================================
       HEADER / TOPBAR
    ============================================== */
    .topbar {
        height: 111px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 40px;
        background: var(--bg-header);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--topbar-border);
        position: relative;
        z-index: 100;
        transition: background 0.4s ease, border-color 0.4s ease;
    }

    .logo-gradient {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: 3px;
        background: linear-gradient(90deg, var(--yellow), var(--orange), var(--red));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        transition: filter 0.3s ease;
    }
    .logo-gradient:hover {
        filter: drop-shadow(0 0 8px rgba(255, 122, 0, 0.5));
    }
    .logo a { text-decoration: none; color: inherit; display: inline-block; }

    .tag {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: 3px;
        background: linear-gradient(90deg, var(--yellow), var(--orange), var(--red));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* =============================================
       THEME SWITCH
    ============================================== */
    .theme-switch {
        --toggle-size: 15px;
        --container-width: 5.625em;
        --container-height: 2.5em;
        --container-radius: 6.25em;
        --container-light-bg: #3D7EAE;
        --container-night-bg: #1D1F2C;
        --circle-container-diameter: 3.375em;
        --sun-moon-diameter: 2.125em;
        --sun-bg: #ECCA2F;
        --moon-bg: #C4C9D1;
        --spot-color: #959DB1;
        --circle-container-offset: calc((var(--circle-container-diameter) - var(--container-height)) / 2 * -1);
        --stars-color: #fff;
        --clouds-color: #F3FDFF;
        --back-clouds-color: #AACADF;
        --transition: .5s cubic-bezier(0, -0.02, 0.4, 1.25);
        --circle-transition: .3s cubic-bezier(0, -0.02, 0.35, 1.17);
        flex-shrink: 0;
        margin-right: 12px;
    }

    .theme-switch, .theme-switch *, .theme-switch *::before, .theme-switch *::after {
        -webkit-box-sizing: border-box;
        box-sizing: border-box;
        margin: 0; padding: 0;
        font-size: var(--toggle-size);
    }

    .theme-switch__container {
        width: var(--container-width);
        height: var(--container-height);
        background-color: var(--container-light-bg);
        border-radius: var(--container-radius);
        overflow: hidden;
        cursor: pointer;
        box-shadow: 0em -0.062em 0.062em rgba(0,0,0,0.25), 0em 0.062em 0.125em rgba(255,255,255,0.94);
        transition: var(--transition);
        position: relative;
    }
    .theme-switch__container::before {
        content: "";
        position: absolute;
        z-index: 1;
        inset: 0;
        box-shadow: 0em 0.05em 0.187em rgba(0,0,0,0.25) inset, 0em 0.05em 0.187em rgba(0,0,0,0.25) inset;
        border-radius: var(--container-radius);
    }
    .theme-switch__checkbox { display: none; }

    .theme-switch__circle-container {
        width: var(--circle-container-diameter);
        height: var(--circle-container-diameter);
        background-color: rgba(255,255,255,0.1);
        position: absolute;
        left: var(--circle-container-offset);
        top: var(--circle-container-offset);
        border-radius: var(--container-radius);
        box-shadow: inset 0 0 0 3.375em rgba(255,255,255,0.1), inset 0 0 0 3.375em rgba(255,255,255,0.1), 0 0 0 0.625em rgba(255,255,255,0.1), 0 0 0 1.25em rgba(255,255,255,0.1);
        display: flex;
        transition: var(--circle-transition);
        pointer-events: none;
    }
    .theme-switch__sun-moon-container {
        pointer-events: auto;
        position: relative;
        z-index: 2;
        width: var(--sun-moon-diameter);
        height: var(--sun-moon-diameter);
        margin: auto;
        border-radius: var(--container-radius);
        background-color: var(--sun-bg);
        box-shadow: 0.062em 0.062em 0.062em 0em rgba(254,255,239,0.61) inset, 0em -0.062em 0.062em 0em #a1872a inset;
        filter: drop-shadow(0.062em 0.125em 0.125em rgba(0,0,0,0.25)) drop-shadow(0em 0.062em 0.125em rgba(0,0,0,0.25));
        overflow: hidden;
        transition: var(--transition);
    }
    .theme-switch__moon {
        transform: translateX(100%);
        width: 100%; height: 100%;
        background-color: var(--moon-bg);
        border-radius: inherit;
        box-shadow: 0.062em 0.062em 0.062em 0em rgba(254,255,239,0.61) inset, 0em -0.062em 0.062em 0em #969696 inset;
        transition: var(--transition);
        position: relative;
    }
    .theme-switch__spot {
        position: absolute;
        top: 0.75em; left: 0.312em;
        width: 0.75em; height: 0.75em;
        border-radius: var(--container-radius);
