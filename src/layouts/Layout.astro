---
// src/layouts/Layout.astro
interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- Space Grotesk for a high-end Tech/Cyber look -->
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>

<body>
    <!-- Abstract Tech Background -->
    <div class="tech-bg">
        <div class="glow-orb orb-1"></div>
        <div class="glow-orb orb-2"></div>
        <div class="grid-overlay"></div>
    </div>

    <!-- Floating Navigation -->
    <nav class="floating-nav">
        <a href="/" class="nav-brand">DXT<span class="accent">3.0</span></a>
        
        <div class="nav-links">
            <a href="/">Inicio</a>
            <a href="/Explorar">Explorar</a>
            <a href="/cronograma">Agenda</a>
            <a href="/categorias">Categorías</a>
            <a href="/reglas">Reglas</a>
            <a href="/agradecimiento">Créditos</a>
        </div>

        <a href="/registro" target="_blank" class="nav-cta">Regístrate</a>
        
        <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Abrir Menú">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        </button>
    </nav>

    <!-- Mobile Nav Overlay -->
    <div class="mobile-nav-overlay" id="mobile-nav">
        <button class="mobile-close-btn" id="mobile-close-btn" aria-label="Cerrar Menú">
            <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="2" fill="none"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
        <div class="mobile-nav-links">
            <a href="/">Inicio</a>
            <a href="/Explorar">Explorar</a>
            <a href="/cronograma">Agenda</a>
            <a href="/categorias">Categorías</a>
            <a href="/reglas">Reglas</a>
            <a href="/agradecimiento">Créditos</a>
            <a href="/registro" target="_blank" class="mobile-cta">Regístrate Ahora</a>
        </div>
    </div>

    <main class="main-content">
        <slot />
    </main>

    <!-- Premium Footer -->
    <footer class="site-footer-bar reveal">
        <div class="footer-divider"></div>
        <div class="footer-inner">
            <div class="footer-org">
                <a href="https://www.instagram.com/ieee_utncs?igsh=Y2VueDJpNW96ZTZw" target="_blank" class="footer-org-link">
                    <img src="/ieee-white-v.svg" alt="IEEE CS UTN" class="footer-logo" />
                    <span class="footer-org-name">IEEE Computer Society</span>
                    <span class="footer-ig">@ieee_utncs</span>
                </a>
            </div>
            <div class="footer-center">
                <span class="footer-badge">DEVXTREME 3.0</span>
                <p class="footer-copy">Universidad Técnica del Norte<br>Ibarra — Ecuador &copy; 2026</p>
            </div>
            <div class="footer-org">
                <a href="https://www.instagram.com/clubprogramacionutn?igsh=ZnJ0OGl1NW9uamxi" target="_blank" class="footer-org-link">
                    <img src="/Utn.svg" alt="Club Programacion UTN" class="footer-logo utn-logo" />
                    <span class="footer-org-name">Club de Programación</span>
                    <span class="footer-ig">@clubprogramacionutn</span>
                </a>
            </div>
        </div>
    </footer>

    <script is:inline>
        // ── MOBILE MENU LOGIC ──
        const mobileBtn = document.getElementById('mobile-menu-btn');
        const closeBtn = document.getElementById('mobile-close-btn');
        const mobileNav = document.getElementById('mobile-nav');

        const toggleMenu = (open) => {
            if (open) {
                mobileNav.classList.add('active');
                document.body.style.overflow = 'hidden';
            } else {
                mobileNav.classList.remove('active');
                document.body.style.overflow = '';
            }
        };

        if(mobileBtn && closeBtn) {
            mobileBtn.addEventListener('click', () => toggleMenu(true));
            closeBtn.addEventListener('click', () => toggleMenu(false));
            
            // Close when clicking a link
            mobileNav.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', () => toggleMenu(false));
            });
        }

        // ── SCROLL ANIMATIONS (IntersectionObserver) ──
        const initScrollReveal = () => {
            const CLASSES = ['reveal', 'reveal-left', 'reveal-right', 'reveal-zoom', 'reveal-scale'];
            const targets = document.querySelectorAll(CLASSES.map(c => '.' + c).join(','));

            if (!targets.length) return;

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('in-view');
                        // Optional: remove observer if you only want it to animate once
                        // observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

            targets.forEach(el => observer.observe(el));
        };

        // Initialize on load and on Astro page swaps
        const init = () => { initScrollReveal(); };
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }
        document.addEventListener('astro:after-swap', init);
    </script>
</body>
</html>

<style is:global>
    /* =============================================
       NEXT-GEN CYBERPUNK VARIABLES (Dark Only)
    ============================================== */
    :root {
        --orange: #ff6b00;
        --orange-light: #ff8c33;
        --orange-glow: rgba(255, 107, 0, 0.4);
        
        --green: #00ff9d;
        --green-light: #33ffa9;
        --green-glow: rgba(0, 255, 157, 0.3);

        --bg-dark: #030305;
        --bg-card: rgba(10, 10, 14, 0.6);
        --bg-nav: rgba(5, 5, 8, 0.7);

        --text-primary: #ffffff;
        --text-secondary: #a1a1aa;
        --text-muted: #71717a;

        --border-subtle: rgba(255, 255, 255, 0.05);
        --border-accent: rgba(255, 107, 0, 0.2);
        
        --glass-blur: blur(24px);
        --shadow-card: 0 8px 32px rgba(0, 0, 0, 0.5);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html {
        scroll-behavior: smooth;
        background-color: var(--bg-dark);
        color: var(--text-primary);
    }

    body {
        font-family: 'Space Grotesk', system-ui, -apple-system, sans-serif;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    /* =============================================
       CINEMATIC BACKGROUND
    ============================================== */
    .tech-bg {
        position: fixed;
        inset: 0;
        z-index: -1;
        background-color: var(--bg-dark);
        overflow: hidden;
    }

    .grid-overlay {
        position: absolute;
        inset: 0;
        background-image: 
            linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
        background-size: 50px 50px;
        mask-image: radial-gradient(ellipse at center, black 20%, transparent 80%);
        -webkit-mask-image: radial-gradient(ellipse at center, black 20%, transparent 80%);
    }

    .glow-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.4;
        animation: floatOrb 20s ease-in-out infinite alternate;
    }

    .orb-1 {
        top: -10%; left: -10%;
        width: 60vw; height: 60vw;
        background: radial-gradient(circle, var(--green-glow) 0%, transparent 70%);
    }

    .orb-2 {
        bottom: -20%; right: -10%;
        width: 70vw; height: 70vw;
        background: radial-gradient(circle, var(--orange-glow) 0%, transparent 70%);
        animation-delay: -10s;
    }

    @keyframes floatOrb {
        0% { transform: translate(0, 0) scale(1); }
        100% { transform: translate(10%, 15%) scale(1.1); }
    }

    .main-content {
        flex: 1;
        position: relative;
        z-index: 10;
        padding-top: 120px; /* Space for floating nav */
    }

    /* =============================================
       FLOATING NAVIGATION PILL
    ============================================== */
    .floating-nav {
        position: fixed;
        top: 24px;
        left: 50%;
        transform: translateX(-50%);
        width: 96%;
        max-width: 1200px;
        height: 70px;
        background: var(--bg-nav);
        backdrop-filter: var(--glass-blur);
        -webkit-backdrop-filter: var(--glass-blur);
        border: 1px solid var(--border-subtle);
        border-radius: 35px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 16px 0 32px;
        z-index: 1000;
        box-shadow: 0 20px 40px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.05);
    }

    .nav-brand {
        font-weight: 700;
        font-size: 1.2rem;
        color: #fff;
        text-decoration: none;
        letter-spacing: -0.5px;
    }
    .nav-brand .accent { color: var(--orange); }

    .nav-links {
        display: flex;
        gap: 24px;
    }

    .nav-links a {
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.3s ease;
        white-space: nowrap;
    }
    .nav-links a:hover { color: #fff; text-shadow: 0 0 12px rgba(255,255,255,0.5); }

    .nav-cta {
        background: linear-gradient(135deg, var(--orange), var(--orange-light));
        color: #000;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.9rem;
        padding: 12px 28px;
        border-radius: 30px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 0 20px var(--orange-glow);
        white-space: nowrap;
    }
    .nav-cta:hover {
        transform: scale(1.05);
        box-shadow: 0 0 30px var(--orange-glow), 0 0 10px rgba(255,255,255,0.4);
    }

    .mobile-menu-btn {
        display: none;
        background: none;
        border: none;
        color: #fff;
        cursor: pointer;
        padding: 8px;
    }

    /* ── MOBILE OVERLAY ── */
    .mobile-nav-overlay {
        position: fixed;
        inset: 0;
        background: rgba(3,3,5,0.95);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        z-index: 2000;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.4s ease;
    }
    .mobile-nav-overlay.active {
        opacity: 1;
        pointer-events: all;
    }

    .mobile-close-btn {
        position: absolute;
        top: 30px;
        right: 30px;
        background: none;
        border: none;
        color: #fff;
        cursor: pointer;
    }

    .mobile-nav-links {
        display: flex;
        flex-direction: column;
        gap: 32px;
        text-align: center;
    }

    .mobile-nav-links a {
        font-size: 2rem;
        font-weight: 600;
        color: var(--text-secondary);
        text-decoration: none;
        transition: color 0.3s ease;
    }
    .mobile-nav-links a:hover { color: var(--green); }

    .mobile-cta {
        margin-top: 20px;
        color: var(--orange) !important;
    }

    /* =============================================
       PREMIUM FOOTER
    ============================================== */
    .site-footer-bar {
        width: 100%;
        margin-top: 100px;
        padding-bottom: 30px;
    }

    .footer-divider {
        width: 100%;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
        margin-bottom: 40px;
    }

    .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 40px;
    }

    .footer-org { display: flex; flex-direction: column; align-items: center; }

    .footer-org-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-decoration: none;
        gap: 8px;
        padding: 12px;
        border-radius: 16px;
        transition: background 0.3s ease, transform 0.3s ease;
    }
    .footer-org-link:hover {
        background: rgba(255,255,255,0.03);
        transform: translateY(-5px);
    }

    .footer-logo {
        height: 40px;
        filter: drop-shadow(0 0 10px rgba(255,255,255,0.1));
        transition: filter 0.3s ease;
    }
    .utn-logo { height: 38px; }

    .footer-org-link:hover .footer-logo {
        filter: drop-shadow(0 0 20px var(--green-glow));
    }

    .footer-org-name { font-size: 0.8rem; font-weight: 600; color: var(--text-secondary); }
    .footer-ig { font-family: monospace; font-size: 0.7rem; color: var(--green); }
    .footer-org-link:hover .footer-org-name { color: #fff; }

    .footer-center {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
        text-align: center;
    }

    .footer-badge {
        font-family: monospace;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 4px;
        color: var(--orange);
        border: 1px solid rgba(255, 107, 0, 0.3);
        padding: 6px 16px;
        border-radius: 30px;
        background: rgba(255, 107, 0, 0.05);
    }

    .footer-copy { font-size: 0.8rem; color: var(--text-muted); line-height: 1.6; }

    /* =============================================
       SCROLL ANIMATIONS
    ============================================== */
    .reveal, .reveal-left, .reveal-right, .reveal-zoom, .reveal-scale {
        opacity: 0;
        will-change: transform, opacity;
        transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .reveal { transform: translateY(40px); }
    .reveal-left { transform: translateX(-40px); }
    .reveal-right { transform: translateX(40px); }
    .reveal-zoom { transform: scale(0.9); }
    .reveal-scale { transform: scale(1.05); }

    .in-view {
        opacity: 1 !important;
        transform: translate(0) scale(1) !important;
    }

    /* Make sure inline styles for delay work with the class */
    .reveal.in-view, .reveal-left.in-view, .reveal-right.in-view, .reveal-zoom.in-view, .reveal-scale.in-view {
        transition-delay: var(--delay, 0s);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
        .nav-links, .nav-cta { display: none; }
        .mobile-menu-btn { display: block; }
        .footer-inner { flex-direction: column; gap: 40px; }
    }
</style>