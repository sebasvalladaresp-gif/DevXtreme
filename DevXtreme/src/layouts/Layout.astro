---
// src/layouts/Layout.astro
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;800&display=swap" rel="stylesheet" />
	</head>
	<body>
		<div class="tech-grid-bg">
			<slot />
		</div>
	</body>
</html>

<style is:global>
	:root {
		--yellow: #ffcc00;
		--orange: #ff7a00;
		--red: #ff004c;
		--bg: #f7f7f7;
		--grid: rgba(255, 120, 0, 0.08);
	}

	* { margin: 0; padding: 0; box-sizing: border-box; }

	body {
		font-family: "Orbitron", sans-serif;
		background: var(--bg);
		color: #222;
	}

	.tech-grid-bg {
		min-height: 100vh;
		background: 
			linear-gradient(var(--grid) 1px, transparent 1px),
			linear-gradient(90deg, var(--grid) 1px, transparent 1px),
			radial-gradient(circle at 20% 30%, rgba(255, 204, 0, 0.1), transparent 40%),
			radial-gradient(circle at 80% 70%, rgba(255, 0, 76, 0.1), transparent 40%),
			#f7f7f7;
		background-size: 50px 50px;
	}
</style>