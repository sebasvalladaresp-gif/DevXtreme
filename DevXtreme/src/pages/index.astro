---
// src/pages/index.astro

const stats = [
  { label: "FECHA", value: "15 MAYO" },
  { label: "INICIO", value: "09:00" },
  { label: "CIERRE", value: "13:00" },
  { label: "DURACIÓN", value: "4 HRS" },
];
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>DevXtreme</title>

    <!-- Fuente futurista -->
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --cyan: #00eaff;
        --pink: #ff2ea6;
        --bg: #02060b;
        --line: rgba(0, 234, 255, 0.08);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Orbitron", sans-serif;
        background: var(--bg);
        color: white;
        overflow-x: hidden;
      }

      /* =========================
         FONDO GRID
      ========================== */
      .tech-grid-bg {
        min-height: 100vh;
        position: relative;
        overflow: hidden;

        background:
          linear-gradient(var(--line) 1px, transparent 1px),
          linear-gradient(90deg, var(--line) 1px, transparent 1px),
          radial-gradient(circle at left, rgba(0, 255, 255, 0.12), transparent 30%),
          radial-gradient(circle at right, rgba(255, 0, 170, 0.12), transparent 30%),
          #02060b;

        background-size: 50px 50px, 50px 50px, auto, auto, auto;
      }

      .tech-grid-bg::before {
        content: "";
        position: absolute;
        inset: 0;

        background: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0.4),
          rgba(0, 0, 0, 0.75)
        );

        pointer-events: none;
      }

      /* =========================
         NAVBAR
      ========================== */
      header {
        position: relative;
        z-index: 2;

        height: 78px;
        padding: 0 64px;

        display: flex;
        justify-content: space-between;
        align-items: center;

        border-bottom: 1px solid rgba(0, 234, 255, 0.12);
      }

      .logo {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: 3px;
      }

      .logo .dev {
        color: var(--cyan);
      }

      .logo .x {
        color: var(--pink);
      }

      .date-box {
        border: 1px solid var(--cyan);
        padding: 10px 24px;

        color: var(--cyan);
        font-size: 0.75rem;
        letter-spacing: 3px;
      }

      /* =========================
         HERO
      ========================== */
      main {
        position: relative;
        z-index: 2;

        min-height: calc(100vh - 78px);

        display: flex;
        justify-content: center;
        align-items: center;

        padding: 50px 20px;
      }

      .hero {
        width: 100%;
        max-width: 1100px;

        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
      }

      .tag {
        color: var(--cyan);
        letter-spacing: 7px;
        font-size: 0.8rem;
        margin-bottom: 30px;
      }

      .title {
        line-height: 0.9;
        margin-bottom: 25px;
      }

      .title .dev-text {
        display: block;

        font-size: clamp(5rem, 12vw, 9rem);
        font-weight: 800;

        color: #ecf4fb;
      }

      .title .xtreme-text {
        display: block;

        font-size: clamp(5rem, 12vw, 9rem);
        font-weight: 800;

        background: linear-gradient(
          90deg,
          #00eaff,
          #4a9cff,
          #8f2fff,
          #ff2ea6
        );

        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;

        text-shadow:
          0 0 10px rgba(0, 234, 255, 0.4),
          0 0 30px rgba(255, 46, 166, 0.25);
      }

      .version {
        margin-top: 8px;
        font-size: 1.5rem;
        letter-spacing: 10px;
        color: rgba(200, 220, 240, 0.35);
      }

      .description {
        margin-top: 45px;

        max-width: 700px;

        font-size: 1rem;
        line-height: 2;
        color: rgba(255, 255, 255, 0.45);
      }

      /* =========================
         CARDS
      ========================== */
      .stats {
        margin-top: 55px;

        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 28px;
      }

      .card {
        width: 170px;
        height: 95px;

        border: 1px solid rgba(0, 234, 255, 0.3);

        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;

        background: rgba(0, 0, 0, 0.2);

        box-shadow: inset 0 0 25px rgba(0, 234, 255, 0.03);
      }

      .card span {
        font-size: 0.72rem;
        color: var(--cyan);
        letter-spacing: 3px;
        margin-bottom: 10px;
      }

      .card h3 {
        font-size: 1.7rem;
        font-weight: 700;
      }

      /* =========================
         BOTONES
      ========================== */
      .buttons {
        display: flex;
        gap: 20px;
        margin-top: 55px;
        flex-wrap: wrap;
        justify-content: center;
      }

      .btn {
        width: 320px;
        height: 74px;

        display: flex;
        justify-content: center;
        align-items: center;

        text-decoration: none;

        border: 2px solid var(--cyan);

        color: var(--cyan);
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: 3px;

        position: relative;
        overflow: hidden;

        transition: 0.3s ease;
      }

      .btn::before {
        content: "";
        position: absolute;
        inset: 0;

        background: linear-gradient(
          90deg,
          rgba(0, 234, 255, 0.15),
          rgba(255, 46, 166, 0.15)
        );

        transform: scaleX(0);
        transform-origin: left;

        transition: 0.3s ease;
      }

      .btn:hover::before {
        transform: scaleX(1);
      }

      .btn:hover {
        box-shadow:
          0 0 15px rgba(0, 234, 255, 0.5),
          0 0 40px rgba(0, 234, 255, 0.15);
      }

      .btn span {
        position: relative;
        z-index: 2;
      }

      /* Segundo botón */
      .secondary-btn {
        border-color: var(--pink);
        color: var(--pink);
      }

      .secondary-btn:hover {
        box-shadow:
          0 0 15px rgba(255, 46, 166, 0.5),
          0 0 40px rgba(255, 46, 166, 0.15);
      }

      /* =========================
         RESPONSIVE
      ========================== */
      @media (max-width: 900px) {
        header {
          padding: 0 20px;
        }

        .stats {
          grid-template-columns: repeat(2, 1fr);
        }

        .card {
          width: 150px;
        }
      }

      @media (max-width: 600px) {
        .logo {
          font-size: 1.4rem;
        }

        .date-box {
          font-size: 0.55rem;
          padding: 8px 12px;
        }

        .stats {
          grid-template-columns: 1fr;
        }

        .card {
          width: 250px;
        }

        .version {
          letter-spacing: 4px;
          font-size: 1rem;
        }

        .btn {
          width: 100%;
          max-width: 300px;
        }
      }
    </style>
  </head>

  <body class="tech-grid-bg">
    <header>
      <div class="logo">
        <span class="dev">DEV</span>
        <span class="x">X</span>
        <span class="dev">TREME</span>
      </div>

      <div class="date-box">15 • MAYO • 2026</div>
    </header>

    <main>
      <section class="hero">
        <p class="tag">// COMPETENCIA DE PROGRAMACIÓN</p>

        <div class="title">
          <span class="dev-text">DEV</span>
          <span class="xtreme-text">XTREME</span>
        </div>

        <div class="version">VERSION_3.0</div>

        <p class="description">
          Demuestra tu dominio del código. Cuatro horas de desafíos
          intensos, pensamiento algorítmico y soluciones que hacen la
          diferencia.
        </p>

        <div class="stats">
          {
            stats.map((item) => (
              <div class="card">
                <span>{item.label}</span>
                <h3>{item.value}</h3>
              </div>
            ))
          }
        </div>

        <!-- BOTONES -->
        <div class="buttons">

          <!-- BOTÓN 1 -->
          <a href="#" class="btn">
            <span>EXPLORAR EVENTO</span>
          </a>

          <!-- BOTÓN 2 -->
          <a
            href="https://docs.google.com/forms/d/e/1FAIpQLSf4WLvdGXD1bmyWqee9N5IfMA6szlF5eUniLZvVFHSRzQWXCw/viewform"
            target="_blank"
            rel="noopener noreferrer"
            class="btn secondary-btn"
          >
            <span>REGISTRARSE</span>
          </a>

        </div>
      </section>
    </main>
  </body>
</html>